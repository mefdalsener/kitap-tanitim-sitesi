@{
	ViewData["Title"] = "Kitap Ekle";
}

<!DOCTYPE html>
<html lang="tr">
<head>
	<meta charset="utf-8" />
	<title>@ViewData["Title"]</title>
	<style>
			* {
				box-sizing: border-box;
				margin: 0;
				padding: 0;
			}

			body {
				font-family: Arial, sans-serif;
				background: #f4f4f4;
				color: #333;
			}

			.admin-header {
				background: linear-gradient(135deg, #1a1a2e 0%, #2d2d5e 100%);
				color: white;
				padding: 20px 32px;
				font-size: 26px;
				font-weight: bold;
				letter-spacing: 0.5px;
				box-shadow: 0 2px 12px rgba(26,26,46,0.25);
			}

			.admin-body {
				max-width: 1000px;
				margin: 32px auto;
				padding: 0 16px;
			}

			/* ORTAK KART TASARIMI — tüm paneller aynı koyu/gradient temada */
			.card {
				background: linear-gradient(135deg, #1a1a2e 0%, #2d2d5e 100%);
				border-radius: 12px;
				padding: 28px;
				margin-bottom: 24px;
				box-shadow: 0 4px 16px rgba(26,26,46,0.25);
			}

				.card h2 {
					color: white;
					font-size: 15px;
					text-transform: uppercase;
					letter-spacing: 1.5px;
					margin-bottom: 18px;
					border-bottom: 1px solid rgba(255,255,255,0.15);
					padding-bottom: 12px;
					font-weight: 700;
				}

				/* ---- ORTAK GİRDİ STİLİ (tüm kartlarda tek tip) ---- */
				.card .form-group,
				.card .scrape-input-group,
				.card .scrape-isbn-group {
					margin-bottom: 14px;
				}

					.card .form-group label,
					.card .scrape-input-group label,
					.card .scrape-isbn-group label {
						display: block;
						font-size: 12px;
						color: rgba(255,255,255,0.7);
						margin-bottom: 6px;
						font-weight: 600;
						letter-spacing: 0.3px;
					}

					.card .form-group input,
					.card .form-group textarea,
					.card .form-group select,
					.card .scrape-input-group input,
					.card .scrape-isbn-group input {
						width: 100%;
						padding: 11px 14px;
						border: 1px solid rgba(255,255,255,0.2);
						border-radius: 8px;
						font-size: 14px;
						font-family: Arial, sans-serif;
						background: rgba(255,255,255,0.08);
						color: white;
						transition: all 0.2s;
					}

					.card .form-group textarea {
						resize: vertical;
						min-height: 80px;
					}

						.card .form-group input::placeholder,
						.card .form-group textarea::placeholder,
						.card .scrape-input-group input::placeholder,
						.card .scrape-isbn-group input::placeholder {
							color: rgba(255,255,255,0.4);
						}

						.card .form-group input:focus,
						.card .form-group textarea:focus,
						.card .form-group select:focus,
						.card .scrape-input-group input:focus,
						.card .scrape-isbn-group input:focus {
							outline: none;
							background: rgba(255,255,255,0.14);
							border-color: #4caf50;
						}

					.card .form-group select option {
						background: #1a1a2e;
						color: white;
					}

			.two-input-row {
				display: flex;
				gap: 12px;
			}

				.two-input-row .form-group {
					flex: 1;
				}

			/* ---- SCRAPE BÖLÜMÜ ALT SATIRI ---- */
			.scrape-bottom-row {
				display: flex;
				align-items: flex-end;
				gap: 16px;
				margin-top: 4px;
			}

			.scrape-isbn-group {
				flex: 1;
			}

			.getir-btn {
				padding: 12px 28px;
				background: #4caf50;
				color: white;
				border: none;
				border-radius: 8px;
				font-size: 14px;
				font-weight: bold;
				cursor: pointer;
				white-space: nowrap;
				display: flex;
				align-items: center;
				gap: 8px;
				transition: background 0.2s, transform 0.1s;
			}

				.getir-btn:hover {
					background: #43a047;
				}

				.getir-btn:active {
					transform: scale(0.97);
				}

				.getir-btn:disabled {
					background: #666;
					cursor: not-allowed;
				}

				.getir-btn .spinner {
					width: 14px;
					height: 14px;
					border: 2px solid rgba(255,255,255,0.4);
					border-top-color: white;
					border-radius: 50%;
					display: none;
					animation: spin 0.7s linear infinite;
				}

				.getir-btn.loading .spinner {
					display: inline-block;
				}

				.getir-btn.loading .btn-label {
					display: none;
				}

			@@keyframes spin {
				to {
					transform: rotate(360deg);
				}
			}

			#getirDurum {
				display: block;
				margin-top: 12px;
				font-size: 13px;
				color: rgba(255,255,255,0.75);
				min-height: 18px;
			}

				#getirDurum.success {
					color: #81c784;
				}

				#getirDurum.error {
					color: #ef9a9a;
				}

			/* İki kolon düzen */
			.two-col {
				display: flex;
				gap: 24px;
				margin-top: 4px;
			}

			.col-left {
				width: 200px;
				flex-shrink: 0;
			}

			.col-right {
				flex: 1;
			}

			/* Resim önizleme */
			.image-preview {
				width: 100%;
				aspect-ratio: 2/3;
				background: rgba(255,255,255,0.06);
				border: 1px dashed rgba(255,255,255,0.25);
				border-radius: 8px;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				margin-bottom: 8px;
			}

				.image-preview img {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}

				.image-preview .placeholder {
					color: rgba(255,255,255,0.45);
					font-size: 13px;
					text-align: center;
					font-weight: bold;
				}

			.url-input {
				width: 100%;
				padding: 9px 12px;
				border: 1px solid rgba(255,255,255,0.2);
				border-radius: 6px;
				font-size: 12px;
				background: rgba(255,255,255,0.08);
				color: white;
			}

				.url-input::placeholder {
					color: rgba(255,255,255,0.4);
				}

			/* + butonlu satır */
			.select-with-add {
				display: flex;
				gap: 8px;
				align-items: center;
			}

				.select-with-add select {
					flex: 1;
				}

			.add-btn {
				width: 38px;
				height: 38px;
				background: #4caf50;
				color: white;
				border: none;
				border-radius: 8px;
				font-size: 18px;
				cursor: pointer;
				flex-shrink: 0;
				display: flex;
				align-items: center;
				justify-content: center;
				transition: background 0.2s;
			}

				.add-btn:hover {
					background: #43a047;
				}

			/* ---- TÜR SEÇİMİ — ETİKET (PILL) STİLİ ---- */
			.pill-group {
				display: flex;
				flex-wrap: wrap;
				gap: 10px;
				padding: 4px 2px;
			}

			.pill {
				display: inline-flex;
				align-items: center;
				gap: 6px;
				padding: 9px 16px;
				border-radius: 999px;
				border: 1px solid rgba(255,255,255,0.25);
				background: rgba(255,255,255,0.06);
				color: rgba(255,255,255,0.8);
				font-size: 13px;
				font-family: Arial, sans-serif;
				cursor: pointer;
				transition: all 0.15s ease;
				user-select: none;
			}

				.pill:hover {
					border-color: rgba(255,255,255,0.5);
					background: rgba(255,255,255,0.12);
					color: white;
				}

				.pill .pill-check {
					display: none;
					font-size: 12px;
					line-height: 1;
				}

				.pill.selected {
					background: #4caf50;
					border-color: #4caf50;
					color: white;
					font-weight: 600;
				}

					.pill.selected .pill-check {
						display: inline;
					}

			.pill-empty-hint {
				font-size: 12px;
				color: rgba(255,255,255,0.4);
				padding: 6px 2px;
			}

			/* Yazar bölümü - yatay düzen */
			.author-row {
				display: flex;
				gap: 24px;
			}

			.author-fields {
				flex: 1;
			}

			.author-image-col {
				width: 140px;
				flex-shrink: 0;
			}

			.author-image-preview {
				width: 100%;
				aspect-ratio: 1/1;
				background: rgba(255,255,255,0.06);
				border: 1px dashed rgba(255,255,255,0.25);
				border-radius: 8px;
				display: flex;
				align-items: center;
				justify-content: center;
				overflow: hidden;
				margin-bottom: 8px;
			}

				.author-image-preview img {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}

				.author-image-preview .placeholder {
					color: rgba(255,255,255,0.45);
					font-size: 12px;
					text-align: center;
					font-weight: bold;
				}

			/* Panel başlığı + kaldır butonu aynı satırda */
			.card-header-row {
				display: flex;
				align-items: center;
				justify-content: space-between;
				gap: 12px;
				border-bottom: 1px solid rgba(255,255,255,0.15);
				padding-bottom: 12px;
				margin-bottom: 18px;
			}

				.card-header-row h2 {
					border-bottom: none;
					margin-bottom: 0;
					padding-bottom: 0;
				}

			.remove-panel-btn {
				background: rgba(244,67,54,0.15);
				border: 1px solid rgba(244,67,54,0.5);
				color: #ff8a80;
				border-radius: 6px;
				font-size: 11px;
				padding: 6px 10px;
				cursor: pointer;
				font-weight: 700;
				white-space: nowrap;
				transition: all 0.2s;
				letter-spacing: 0.3px;
			}

				.remove-panel-btn:hover {
					background: rgba(244,67,54,0.3);
					color: white;
				}

			/* "Çevirmen Ekle" / "Yazar Ekle" butonu - panel grubunun ALTINDA yer alır */
			.add-more-btn {
				display: block;
				width: 100%;
				padding: 13px;
				background: rgba(255,255,255,0.9);
				border: 1px dashed rgba(45,45,94,0.4);
				color: #2d2d5e;
				border-radius: 10px;
				font-size: 14px;
				font-weight: 700;
				cursor: pointer;
				margin: -8px 0 24px 0;
				transition: all 0.2s;
			}

				.add-more-btn:hover {
					background: white;
					border-color: #2d2d5e;
					transform: translateY(-1px);
				}

			/* Kaydet butonu */
			.save-btn {
				width: 100%;
				padding: 15px;
				background: #2e7d32;
				color: white;
				border: none;
				border-radius: 10px;
				font-size: 16px;
				font-weight: bold;
				cursor: pointer;
				margin-top: 8px;
				box-shadow: 0 4px 14px rgba(46,125,50,0.35);
				transition: background 0.2s, transform 0.1s;
			}

				.save-btn:hover {
					background: #1b5e20;
				}

				.save-btn:active {
					transform: scale(0.99);
				}

			/* POPUP */
			.popup-overlay {
				display: none;
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(0,0,0,0.5);
				z-index: 100;
				align-items: center;
				justify-content: center;
			}

				.popup-overlay.active {
					display: flex;
				}

			.popup-box {
				background: linear-gradient(135deg, #1a1a2e 0%, #2d2d5e 100%);
				border-radius: 12px;
				padding: 26px;
				width: 340px;
				box-shadow: 0 8px 32px rgba(0,0,0,0.35);
			}

				.popup-box h3 {
					font-size: 15px;
					margin-bottom: 16px;
					color: white;
					text-transform: uppercase;
					letter-spacing: 1px;
				}

				.popup-box input {
					width: 100%;
					padding: 11px 14px;
					border: 1px solid rgba(255,255,255,0.2);
					border-radius: 8px;
					font-size: 14px;
					margin-bottom: 16px;
					background: rgba(255,255,255,0.08);
					color: white;
				}

					.popup-box input::placeholder {
						color: rgba(255,255,255,0.4);
					}

					.popup-box input:focus {
						outline: none;
						background: rgba(255,255,255,0.14);
						border-color: #4caf50;
					}

			.popup-buttons {
				display: flex;
				gap: 10px;
				justify-content: flex-end;
			}

				.popup-buttons button {
					padding: 9px 20px;
					border-radius: 8px;
					border: none;
					cursor: pointer;
					font-size: 14px;
					font-weight: 600;
					transition: background 0.2s;
				}

			.btn-confirm {
				background: #4caf50;
				color: white;
			}

				.btn-confirm:hover {
					background: #43a047;
				}

			.btn-cancel {
				background: rgba(255,255,255,0.1);
				color: white;
			}

				.btn-cancel:hover {
					background: rgba(255,255,255,0.18);
				}

			/* ---- ALAN UYARISI (kırmızı, örn. seri sıralaması çakışması) ---- */
			.field-warning {
				display: none;
				margin-top: 6px;
				font-size: 12.5px;
				color: #ff6b6b;
				font-weight: 600;
				line-height: 1.5;
				background: rgba(255,107,107,0.1);
				border: 1px solid rgba(255,107,107,0.35);
				border-radius: 6px;
				padding: 8px 10px;
			}

			/* ---- ÜST BİLGİ BANNER'I (alert() yerine) ---- */
			.top-notice {
				position: fixed;
				top: -80px;
				left: 50%;
				transform: translateX(-50%);
				background: #2e7d32;
				color: white;
				padding: 14px 26px;
				border-radius: 10px;
				font-size: 14px;
				font-weight: 600;
				box-shadow: 0 8px 24px rgba(0,0,0,0.35);
				z-index: 999;
				transition: top 0.3s ease;
				max-width: 90%;
				text-align: center;
			}

				.top-notice.show {
					top: 20px;
				}

				.top-notice.error {
					background: #c62828;
				}

			/* ---- ISBN / LİNK KARŞILIKLI DIŞLAMA NOTU ---- */
			.exclusivity-note {
				display: none;
				margin-top: 10px;
				font-size: 12.5px;
				color: #ffd54f;
				background: rgba(255,213,79,0.1);
				border: 1px solid rgba(255,213,79,0.3);
				border-radius: 6px;
				padding: 8px 12px;
				line-height: 1.5;
			}

			/* ---- DÜZENLEME MODU (ISBN'den kitap çekildiğinde Kaydet -> Güncelle) ---- */
			.save-btn.edit-mode {
				background: #1565c0;
				box-shadow: 0 4px 14px rgba(21,101,192,0.4);
			}

				.save-btn.edit-mode:hover {
					background: #0d47a1;
				}

			.edit-mode-banner {
				display: none;
				background: rgba(21,101,192,0.15);
				border: 1px solid rgba(21,101,192,0.4);
				border-radius: 8px;
				padding: 10px 14px;
				font-size: 13px;
				color: #90caf9;
				margin-bottom: 16px;
				font-weight: 600;
			}

			.card input:disabled,
			.card select:disabled {
				opacity: 0.4;
				cursor: not-allowed;
			}
	</style>
</head>
<body>
	<!-- BAŞLIK PANELİ -->
	<div class="admin-header" id="adminHeaderTitle">Admin Paneli — Kitap Ekle</div>

	<div class="admin-body">

		<!-- OTOMATİK VERİ ÇEKME KARTI -->
		<div class="card" id="scrapePaneli">
			<h2>🔗 Kitapyurdu ve Goodreads Linklerinden Otomatik Doldur</h2>

			<div class="scrape-input-group">
				<label>Kitapyurdu Linki</label>
				<input type="text" id="kitapyurduUrl" placeholder="https://www.kitapyurdu.com/kitap/..." oninput="updateExclusivity()" />
			</div>

			<div class="scrape-input-group">
				<label>Goodreads Linki</label>
				<input type="text" id="goodreadsUrl" placeholder="https://www.goodreads.com/book/show/..." oninput="updateExclusivity()" />
			</div>

			<div class="scrape-bottom-row">
				<button class="getir-btn" id="getirBtn" onclick="getirVeDoldur()">
					<span class="spinner"></span>
					<span class="btn-label">⬇ Getir</span>
				</button>
				<button type="button" class="getir-btn" id="linkTemizleBtn" style="background:#555;" onclick="linkleriTemizle()" title="Link kutularını temizle ve ISBN moduna hızlı geç">
					<span class="btn-label">✕ Temizle</span>
				</button>
			</div>

			<span id="getirDurum"></span>
			<div id="eslesmeSonuclari" style="margin-top:8px; font-size:13px; color:#81c784; line-height:1.6;"></div>
			<div class="exclusivity-note" id="booklandDisableNote" style="display:none;">
				⚠ Bookland üzerinden bir kitabı düzenlemek için geldiniz. Karışıklığı önlemek amacıyla bu panel bu oturumda devre dışı bırakıldı.
			</div>
			<div class="exclusivity-note" id="linkExclusivityNote">
				⚠ ISBN girildiği için link alanları devre dışı bırakıldı. Link ile devam etmek için önce ISBN kutusunu boşaltın.
			</div>
		</div>

		<!-- ISBN KARTI (kendi bloğu — otomatik doldur ile kitap bilgileri arasında) -->
		<div class="card" id="isbnCard">
			<h2>📖 ISBN</h2>
			<div class="scrape-bottom-row">
				<div class="scrape-isbn-group">
					<label>ISBN</label>
					<input type="text" id="isbnInput" placeholder="ISBN girin..." oninput="onIsbnInputChange()" />
				</div>
				<button class="getir-btn" id="isbnGetirBtn" onclick="isbnGetir()">
					<span class="spinner"></span>
					<span class="btn-label">🔎 Getir</span>
				</button>
				<button type="button" class="getir-btn" style="background:#555;" onclick="isbnTemizle()" title="ISBN kutusunu temizle ve link moduna hızlı geç">
					<span class="btn-label">✕ Temizle</span>
				</button>
			</div>
			<span id="isbnDurum" style="display:block; margin-top:12px; font-size:13px; color:rgba(255,255,255,0.75); min-height:18px;"></span>
			<div class="exclusivity-note" id="isbnExclusivityNote">
				⚠ Link girildiği için ISBN alanı devre dışı bırakıldı. ISBN ile devam etmek için önce link kutularını boşaltın.
			</div>
			<div style="margin-top:8px; font-size:12px; color:rgba(255,255,255,0.45);">
				Bu "Getir" butonu internetten veri çekmez, sadece veritabanında bu ISBN'ye kayıtlı bir kitap olup olmadığına bakar.
			</div>
		</div>

		<!-- KİTAP BİLGİLERİ -->
		<div class="card" id="kitapBilgileriCard">
			<h2>📘 Kitap Bilgileri</h2>
			<div class="edit-mode-banner" id="editModeBanner"></div>
			<div class="two-col">

				<!-- Sol: Kapak resmi -->
				<div class="col-left">
					<div class="image-preview" id="coverPreview">
						<span class="placeholder">Kapak Resmi</span>
					</div>
					<input type="text" class="url-input" id="coverUrl"
						   placeholder="Kapak URL'si..."
						   oninput="onCoverUrlChange()" />
				</div>

				<!-- Sağ: Form alanları -->
				<div class="col-right">

					<div class="form-group">
						<label>Kitap Adı</label>
						<input type="text" id="bookName" placeholder="Kitap adı..." />
					</div>

					<div class="form-group">
						<label>İlk Basım Yılı</label>
						<input type="number" id="firstPublishYear" placeholder="Örn: 1866" />
					</div>

					<div class="form-group">
						<label>Kitap Açıklaması</label>
						<textarea id="bookDescription" placeholder="Kitap hakkında kısa açıklama..."></textarea>
					</div>

					<div class="form-group">
						<label>Seri</label>
						<div class="select-with-add">
							<select id="seriesSelect" onchange="checkSeriesOrderConflict()">
								<option value="">— Seri seçin —</option>
								<!-- Seriler veritabanından gelecek -->
							</select>
							<button class="add-btn" onclick="popupAc('seri')" title="Yeni seri ekle">+</button>
						</div>
					</div>

					<div class="form-group">
						<label>Seri Sıralaması</label>
						<input type="number" id="seriesOrder" placeholder="Örn: 1" oninput="checkSeriesOrderConflict()" />
						<div class="field-warning" id="seriesOrderWarning"></div>
					</div>

					<div class="form-group">
						<label>Tür (birden fazla seçebilirsiniz)</label>
						<div class="pill-group" id="genreSelect">
							<!-- Türler JS ile (veritabanından gelen listeyle) render ediliyor -->
						</div>
					</div>

					<div class="two-input-row">
						<div class="form-group">
							<label>Sayfa Sayısı</label>
							<input type="number" id="pageCount" placeholder="Örn: 320" />
						</div>
						<div class="form-group">
							<label>Basım Yılı</label>
							<input type="number" id="publishYear" placeholder="Örn: 2023" />
						</div>
					</div>

					<div class="form-group">
						<label>Yayınevi</label>
						<div class="select-with-add">
							<select id="publisherSelect">
								<option value="">— Yayınevi seçin —</option>
								<!-- Yayınevleri veritabanından gelecek -->
							</select>
							<button class="add-btn" onclick="popupAc('yayinevi')" title="Yeni yayınevi ekle">+</button>
						</div>
					</div>

				</div>
			</div>
		</div>

		<!-- ÇEVİRMEN (çoklu çevirmen destekli) -->
		<div id="translatorsSection">
			<div id="translatorsContainer"></div>
			<button type="button" class="add-more-btn" id="cevirmenEkleBtn" onclick="cevirmenEkle()">➕ Çevirmen Ekle</button>
		</div>

		<!-- YAZAR BİLGİLERİ (çoklu yazar destekli) -->
		<div id="authorsContainer"></div>
		<button type="button" class="add-more-btn" id="yazarEkleBtn" onclick="yazarEkle()">➕ Yazar Ekle</button>

		<!-- KAYDET -->
		<button class="save-btn" id="saveBtn" onclick="kaydet()">💾 Kaydet</button>

	</div>

	<!-- POPUP: Yeni Seri -->
	<div class="popup-overlay" id="popupSeri">
		<div class="popup-box">
			<h3>Yeni Seri Ekle</h3>
			<input type="text" id="yeniSeriAdi" placeholder="Seri adı..." />
			<div class="popup-buttons">
				<button class="btn-cancel" onclick="popupKapat('seri')">İptal</button>
				<button class="btn-confirm" onclick="seriKaydet()">Ekle</button>
			</div>
		</div>
	</div>

	<!-- POPUP: Yeni Yayınevi -->
	<div class="popup-overlay" id="popupYayinevi">
		<div class="popup-box">
			<h3>Yeni Yayınevi Ekle</h3>
			<input type="text" id="yeniYayineviAdi" placeholder="Yayınevi adı..." />
			<div class="popup-buttons">
				<button class="btn-cancel" onclick="popupKapat('yayinevi')">İptal</button>
				<button class="btn-confirm" onclick="yayineviKaydet()">Ekle</button>
			</div>
		</div>
	</div>

	<script>
			// ---- TÜR (GENRE) LİSTESİ ----
			let allGenres = [
				"Kurgu", "Kurgu Dışı", "Fantastik", "Epik Fantastik", "Yüksek Fantastik",
				"Fantastik-Bilim Kurgu", "Büyü", "Macera", "Klasik", "Felsefe",
				"Polisiye", "Tarih", "Politik", "Sosyoloji", "Bilim Kurgu",
				"Tarihi Kurgu", "Gizem", "Gerilim", "Korku", "Romantik",
				"Bilim", "Psikoloji", "Biyografi", "Anı", "Şiir",
				"Çocuk", "Genç Yetişkin", "Çizgi Roman", "Grafik Roman", "Manga",
				"Sanat", "Müzik", "Seyahat", "Yemek", "Din",
				"Maneviyat", "Kişisel Gelişim", "İş Dünyası / Ekonomi"
			];
			let selectedGenres = new Set();

			const genreMapEnToTr = {
				"art": "Sanat",
				"adventure": "Macera",
				"biography": "Biyografi",
				"business": "İş Dünyası / Ekonomi",
				"children's": "Çocuk",
				"christian": "Din",
				"classics": "Klasik",
				"comics": "Çizgi Roman",
				"contemporary": "Kurgu",
				"cookbooks": "Yemek",
				"crime": "Polisiye",
				"epic fantasy": "Epik Fantastik",
				"fantasy": "Fantastik",
				"fiction": "Kurgu",
				"graphic novels": "Grafik Roman",
				"high fantasy": "Yüksek Fantastik",
				"historical fiction": "Tarihi Kurgu",
				"history": "Tarih",
				"horror": "Korku",
				"magic": "Büyü",
				"manga": "Manga",
				"memoir": "Anı",
				"music": "Müzik",
				"mystery": "Gizem",
				"nonfiction": "Kurgu Dışı",
				"paranormal": "Fantastik",
				"philosophy": "Felsefe",
				"poetry": "Şiir",
				"politics": "Politik",
				"psychology": "Psikoloji",
				"religion": "Din",
				"romance": "Romantik",
				"science": "Bilim",
				"science fiction": "Bilim Kurgu",
				"science fiction fantasy": "Fantastik-Bilim Kurgu",
				"self help": "Kişisel Gelişim",
				"sociology": "Sosyoloji",
				"suspense": "Gerilim",
				"spirituality": "Maneviyat",
				"thriller": "Gerilim",
				"travel": "Seyahat",
				"young adult": "Genç Yetişkin"
			};

			function mapGenreToTurkish(englishGenre) {
				if (!englishGenre) return null;
				const key = englishGenre.trim().toLocaleLowerCase('en-US');
				return genreMapEnToTr[key] || null;
			}

			// Bu ikisi her zaman en başta sabit kalır, alfabetik sıralamaya girmez
			const PINNED_GENRES = ["Kurgu", "Kurgu Dışı"];

			function getOrderedGenres() {
				const pinned = PINNED_GENRES.filter(g => allGenres.includes(g));
				const rest = allGenres.filter(g => !PINNED_GENRES.includes(g));

				// Kalanlar: önce seçili olanlar (kendi aralarında alfabetik),
				// sonra seçili olmayanlar (kendi aralarında alfabetik).
				// Böylece seçilenler Kurgu / Kurgu Dışı'nın hemen sağına taşınır.
				const secili = rest.filter(g => selectedGenres.has(g)).sort((a, b) => a.localeCompare(b, 'tr-TR'));
				const secilmemis = rest.filter(g => !selectedGenres.has(g)).sort((a, b) => a.localeCompare(b, 'tr-TR'));

				return [...pinned, ...secili, ...secilmemis];
			}

			function renderGenrePills() {
				const container = document.getElementById('genreSelect');
				container.innerHTML = '';

				if (allGenres.length === 0) {
					const hint = document.createElement('div');
					hint.className = 'pill-empty-hint';
					hint.textContent = 'Tür listesi yükleniyor...';
					container.appendChild(hint);
					return;
				}

				getOrderedGenres().forEach(genre => {
					const pill = document.createElement('button');
					pill.type = 'button';
					pill.className = 'pill' + (selectedGenres.has(genre) ? ' selected' : '');
					pill.setAttribute('data-genre', genre);
					pill.innerHTML = '<span class="pill-check">✓</span><span>' + genre + '</span>';
					pill.onclick = () => toggleGenre(genre);
					container.appendChild(pill);
				});
			}

			function toggleGenre(genre) {
				if (selectedGenres.has(genre)) {
					selectedGenres.delete(genre);
				} else {
					selectedGenres.add(genre);
				}
				renderGenrePills();
			}

			function getSelectedGenres() {
				return Array.from(selectedGenres);
			}

			// ================== SQL DROPDOWN VERİLERİ ==================
			let dbSeries = [];
			let dbPublishers = [];
			let dbTranslators = [];
			let dbAuthors = [];
			let dbBooks = []; // seri sıralaması çakışma kontrolü için
			let editingBookId = null; // ISBN'den kitap çekilirse burada dolar -> Kaydet, Güncelle'ye döner
			let editingAuthorId = null; // authorId ile bağımsız yazar düzenleme moduna girilirse burada dolar
			let editModeTetikleyici = null; // 'isbn' | 'bookId' | null — düzenleme moduna hangi akıştan girildiğini tutar
			let booklandModuAktif = false; // Bookland'dan bookId ile gelindiyse true olur, link paneli kalıcı olarak kapatılır

			// ---- Bookland'dan bookId ile gelindiğinde "Linklerden Otomatik Doldur" panelini
			//      tamamen görünmez yapar (devre dışı bırakmak yerine gizler) ----
			function linkPaneliniDevreDisiBirak() {
				booklandModuAktif = true;
				document.getElementById('kitapyurduUrl').disabled = true;
				document.getElementById('goodreadsUrl').disabled = true;
				document.getElementById('getirBtn').disabled = true;
				document.getElementById('linkTemizleBtn').disabled = true;
				document.getElementById('scrapePaneli').style.display = 'none';
			}

			// ---- ISBN kutusu değiştiğinde: dışlamayı güncelle + gerekirse düzenleme modundan çık ----
			function onIsbnInputChange() {
				updateExclusivity();

				const isbnVal = document.getElementById('isbnInput').value.trim();
				// ISBN, düzenleme modunu tetikleyen alan olduğu ve şimdi boşaltıldıysa moddan çık.
				// (Bookland üzerinden bookId ile girilen düzenleme modunda ISBN sadece bilgi amaçlıdır,
				// silinmesi o modu bozmamalı.)
				if (!isbnVal && editingBookId && editModeTetikleyici === 'isbn') {
					editingBookId = null;
					editModeTetikleyici = null;
					setSaveButtonMode(false);
					const durum = document.getElementById('isbnDurum');
					durum.className = '';
					durum.textContent = 'ISBN temizlendi, düzenleme modundan çıkıldı.';
				}
			}

			// ---- Link veya ISBN alanlarını tek tıkla temizleyip moda hızlı geçiş sağlar ----
			function linkleriTemizle() {
				document.getElementById('kitapyurduUrl').value = '';
				document.getElementById('goodreadsUrl').value = '';
				updateExclusivity();
			}

			function isbnTemizle() {
				document.getElementById('isbnInput').value = '';
				onIsbnInputChange();
			}

			// ---- ISBN alanı ile Link alanları birbirini dışlar ----
			function updateExclusivity() {
				const kyVal = document.getElementById('kitapyurduUrl').value.trim();
				const grVal = document.getElementById('goodreadsUrl').value.trim();
				const isbnVal = document.getElementById('isbnInput').value.trim();

				const linkVarMi = !!(kyVal || grVal);
				const isbnVarMi = !!isbnVal;

				const isbnInput = document.getElementById('isbnInput');
				const isbnGetirBtn = document.getElementById('isbnGetirBtn');
				const kyInput = document.getElementById('kitapyurduUrl');
				const grInput = document.getElementById('goodreadsUrl');
				const linkGetirBtn = document.getElementById('getirBtn');
				const isbnNote = document.getElementById('isbnExclusivityNote');
				const linkNote = document.getElementById('linkExclusivityNote');

				if (linkVarMi && !isbnVarMi) {
					isbnInput.disabled = true;
					isbnGetirBtn.disabled = true;
					isbnNote.style.display = 'block';
				} else {
					isbnInput.disabled = false;
					isbnGetirBtn.disabled = false;
					isbnNote.style.display = 'none';
				}

				if (isbnVarMi && !linkVarMi) {
					kyInput.disabled = true;
					grInput.disabled = true;
					linkGetirBtn.disabled = true;
					linkNote.style.display = 'block';
				} else if (!booklandModuAktif) {
					// Bookland modunda link kutuları kalıcı olarak kapalı kalmalı;
					// bu dal sadece normal (Bookland dışı) akışta çalışır.
					kyInput.disabled = false;
					grInput.disabled = false;
					linkGetirBtn.disabled = false;
					linkNote.style.display = 'none';
				}
			}

			// ---- Kaydet / Güncelle buton durumunu ayarla ----
			function setSaveButtonMode(isEditing) {
				const btn = document.getElementById('saveBtn');
				const banner = document.getElementById('editModeBanner');
				if (isEditing) {
					btn.textContent = '🔄 Güncelle';
					btn.classList.add('edit-mode');
					banner.style.display = 'block';
					banner.textContent = '✏️ Düzenleme modundasınız: ISBN ile bulunan kitap üzerinde değişiklik yapıyorsunuz. Kaydet butonu artık "Güncelle" olarak çalışacak.';
				} else {
					btn.textContent = '💾 Kaydet';
					btn.classList.remove('edit-mode');
					banner.style.display = 'none';
					banner.textContent = '';
				}
			}

			// ---- ISBN ile SADECE veritabanından kitap arama (internet çekme yok) ----
			// ---- Ortak: gelen kitap verisiyle formu doldurup düzenleme moduna geçirir ----
			// (ISBN "Getir" akışı ve Bookland'daki "Düzenle" butonu tarafından ortak kullanılır)
			function formuDoldurVeDuzenlemeModunaGec(data) {
				document.getElementById('bookName').value = data.book.bookName || '';
				document.getElementById('firstPublishYear').value = data.book.firstPublishYear || '';
				document.getElementById('bookDescription').value = data.book.bookDescription || '';
				document.getElementById('coverUrl').value = data.book.bookCoverImageUrl || '';
				onCoverUrlChange();

				document.getElementById('seriesSelect').value = data.book.seriesId || '';
				document.getElementById('seriesOrder').value = data.book.seriesOrder || '';

				// Backend "authors" (dizi, çoklu yazar) veya eski "author" (tekil) alanlarından
				// hangisini gönderiyorsa onu kabul eder.
				yazarPanelleriniVeriyleDoldur(data.authors || data.author);

				if (data.publisher && data.publisher.id) {
					document.getElementById('publisherSelect').value = data.publisher.id;
				}

				// Backend "translators" (dizi, çoklu çevirmen) veya eski "translator" (tekil)
				// alanlarından hangisini gönderiyorsa onu kabul eder.
				cevirmenPanelleriniVeriyleDoldur(data.translators || data.translator);

				document.getElementById('pageCount').value = data.bookPublisher.pageCount || '';
				document.getElementById('publishYear').value = data.bookPublisher.publishYear || '';

				selectedGenres = new Set(data.genres || []);
				renderGenrePills();

				editingBookId = data.bookId;
				setSaveButtonMode(true);
				checkSeriesOrderConflict();
			}

			// ---- ISBN ile SADECE veritabanından kitap arama (internet çekme yok) ----
			async function isbnGetir() {
				const isbn = document.getElementById('isbnInput').value.trim();
				const durum = document.getElementById('isbnDurum');

				if (!isbn) {
					alert('ISBN girmelisiniz.');
					return;
				}

				durum.className = '';
				durum.textContent = 'Veritabanında aranıyor...';

				try {
					const res = await fetch('/Admin/GetBookByIsbn?isbn=' + encodeURIComponent(isbn));
					const data = await res.json();

					if (data.error) {
						durum.className = 'error';
						durum.textContent = 'Hata: ' + data.error;
						return;
					}

					if (!data.found) {
						durum.className = '';
						durum.textContent = 'Bu ISBN veritabanında kayıtlı değil. Yeni kitap olarak devam edebilirsiniz.';
						editingBookId = null;
						editModeTetikleyici = null;
						setSaveButtonMode(false);
						return;
					}

					formuDoldurVeDuzenlemeModunaGec(data);
					editModeTetikleyici = 'isbn';

					durum.className = 'success';
					durum.textContent = `✓ Kayıtlı kitap bulundu: "${data.book.bookName}". Düzenleme modundasınız.`;
				} catch (err) {
					durum.className = 'error';
					durum.textContent = 'Bağlantı hatası: ' + err.message;
				}
			}

			// ---- Bookland popup'ındaki "Düzenle" butonundan bookId ile gelinmişse
			//      formu otomatik doldurup düzenleme moduna geçer ----
			async function urlDenBookIdIleDoldur() {
				const params = new URLSearchParams(window.location.search);
				const bookId = params.get('bookId');
				if (!bookId) return;

				try {
					const res = await fetch('/Admin/GetBookById?bookId=' + encodeURIComponent(bookId));
					const data = await res.json();

					if (data.error || !data.found) {
						console.error('Bookland üzerinden gelen bookId bulunamadı:', data.error || 'kitap yok');
						return;
					}

					formuDoldurVeDuzenlemeModunaGec(data);
					editModeTetikleyici = 'bookId';

					// Bookland üzerinden bookId ile gelindi: sayfa başlığını düzenleme moduna
					// göre günceller.
					document.getElementById('adminHeaderTitle').textContent = 'Admin Paneli — Kitap Düzenleme';

					// Bookland üzerinden gelindi: "Linklerden Otomatik Doldur" paneli bu kitap
					// zaten veritabanında kayıtlı olduğu için gereksiz ve kafa karıştırıcı —
					// bu oturum boyunca kapatılır (tamamen gizlenir).
					linkPaneliniDevreDisiBirak();

					if (data.bookPublisher && data.bookPublisher.isbn) {
						document.getElementById('isbnInput').value = data.bookPublisher.isbn;
					}

					// KRİTİK: ISBN kutusu burada programatik olarak dolduruluyor, bu da 'oninput'
					// olayını tetiklemiyor. updateExclusivity() elle çağrılmazsa link kutuları
					// ISBN dolu olsa bile aktif kalır (bkz. bildirilen 2 ve 3 numaralı hatalar).
					updateExclusivity();

					const durum = document.getElementById('isbnDurum');
					durum.className = 'success';
					durum.textContent = `✓ Bookland üzerinden açıldı: "${data.book.bookName}". Düzenleme modundasınız.`;
				} catch (err) {
					console.error('bookId ile otomatik doldurma başarısız:', err);
				}
			}

			// ---- Bookland popup'ındaki "Yazarı Düzenle" akışından authorId ile gelinmişse
			//      kitap/çevirmen ile ilgili panel ve butonları tamamen gizler, yazar
			//      bilgilerini veritabanından çekip forma doldurur ve sayfayı bağımsız
			//      "Yazar Düzenleme" moduna geçirir ----
			async function urlDenAuthorIdIleModAyarla() {
				const params = new URLSearchParams(window.location.search);
				const authorId = params.get('authorId');
				if (!authorId) return;

				document.getElementById('adminHeaderTitle').textContent = 'Admin Paneli — Yazar Düzenleme';

				// Yazar düzenleme modunda kitaba özgü paneller ve "ekle" butonları
				// kullanılamaz ve tamamen görünmez hale gelir.
				document.getElementById('scrapePaneli').style.display = 'none';
				document.getElementById('isbnCard').style.display = 'none';
				document.getElementById('kitapBilgileriCard').style.display = 'none';
				document.getElementById('translatorsSection').style.display = 'none';
				document.getElementById('yazarEkleBtn').style.display = 'none';

				try {
					const res = await fetch(`/Admin/GetAuthorById?authorId=${encodeURIComponent(authorId)}`);
					const data = await res.json();

					if (!data.found) {
						showTopNotice('Yazar bulunamadı.', true);
						return;
					}

					document.getElementById('authorName_0').value = toTitleCase(data.author.name) || '';
					document.getElementById('authorSurname_0').value = toTitleCase(data.author.surname) || '';
					document.getElementById('authorBio_0').value = data.author.biography || '';
					document.getElementById('authorBirthYear_0').value = data.author.birthYear || '';
					document.getElementById('authorDeathYear_0').value = data.author.deathYear || '';
					document.getElementById('authorUrl_0').value = data.author.imageUrl || '';
					onAuthorUrlChange(0);

					editingAuthorId = data.author.id;
					setSaveButtonMode(true);
					document.getElementById('editModeBanner').textContent =
						'✏️ Düzenleme modundasınız: Yazar bilgilerini güncelliyorsunuz. Kaydet butonu artık "Güncelle" olarak çalışacak.';
				} catch (err) {
					showTopNotice('Yazar bilgisi alınırken bağlantı hatası oluştu.', true);
				}
			}

			async function loadDropdownData() {
				try {
					const res = await fetch('/Admin/GetSelectData');
					const data = await res.json();

					dbSeries = data.series || [];
					dbPublishers = data.publishers || [];
					dbTranslators = data.translators || [];
					dbAuthors = data.authors || [];
					dbBooks = data.books || [];

					renderSimpleSelect('seriesSelect', dbSeries, s => toTitleCase(s.name), '— Seri seçin —');
					renderSimpleSelect('publisherSelect', dbPublishers, p => toTitleCase(p.name), '— Yayınevi seçin —');
					renderTranslatorOptions();
					renderAuthorOptions();
				} catch (err) {
					console.error('Dropdown verileri yüklenemedi:', err);
				}
			}

			function renderSimpleSelect(selectId, items, labelFn, placeholderText) {
				const select = document.getElementById(selectId);
				select.innerHTML = '';
				const placeholderOption = new Option(placeholderText, '');
				// Bu seçenek gerçek bir seçim değil — kaydederken bunu yanlışlıkla
				// bir isim (örn. yayınevi adı) olarak göndermemek için işaretliyoruz.
				placeholderOption.setAttribute('data-placeholder', '1');
				select.add(placeholderOption);
				items.forEach(item => select.add(new Option(labelFn(item), item.id)));
			}

			// Çoklu çevirmen desteği: sayfadaki TÜM çevirmen panellerinin select'lerini
			// günceller, o an seçili olan değeri (varsa) korur.
			function renderTranslatorOptions() {
				document.querySelectorAll('.translatorSelect').forEach(select => {
					const currentVal = select.value;
					select.innerHTML = '';
					select.add(new Option('— Çevirmen seçin veya yeni çevirmen girin —', ''));
					select.add(new Option('+ Yeni Çevirmen', 'yeni'));
					dbTranslators.forEach(t => select.add(new Option(toTitleCase(`${t.name} ${t.surname}`), t.id)));
					if ([...select.options].some(o => o.value === currentVal)) {
						select.value = currentVal;
					}
				});
			}

			// Çoklu yazar desteği: sayfadaki TÜM yazar panellerinin select'lerini günceller.
			function renderAuthorOptions() {
				document.querySelectorAll('.authorSelect').forEach(select => {
					const currentVal = select.value;
					select.innerHTML = '';
					select.add(new Option('— Yazar seçin veya yeni yazar girin —', ''));
					select.add(new Option('+ Yeni Yazar', 'yeni'));
					dbAuthors.forEach(a => select.add(new Option(toTitleCase(`${a.name} ${a.surname}`), a.id)));
					if ([...select.options].some(o => o.value === currentVal)) {
						select.value = currentVal;
					}
				});
			}

			// ================== ÇOKLU YAZAR / ÇEVİRMEN PANEL YÖNETİMİ ==================
			// Her panel, benzersiz bir index taşır (id="authorName_3" gibi). Böylece
			// aynı anda birden fazla yazar/çevirmen paneli sayfada bulunabilir.
			let translatorPanelCount = 0;
			let authorPanelCount = 0;

			function translatorPanelHtml(index) {
				return `
			<div class="card translator-panel" data-index="${index}">
				<div class="card-header-row">
