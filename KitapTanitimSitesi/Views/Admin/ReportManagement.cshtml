@{
    ViewData["Title"] = "Talep/Şikayet Yönetimi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin-panel.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    <!--
        Aşağıdaki stiller SADECE bu sayfaya özgü (rapor şeridi, tip/durum
        rozetleri, hedef yorum kutusu). admin-panel.css'e eklenmedi —
        UserManagement/CommentModeration'daki aynı gerekçe.
    -->
    <style>
            /* ---- SAYFA TEMASI — Talep/Şikayet Yönetimi (lacivert/amber).
                                                                                   Diğer panellerden ayrışsın diye. ---- */
            .admin-header {
                background: linear-gradient(135deg, #1a1a3d 0%, #6b4f1f 100%);
                box-shadow: 0 2px 12px rgba(26,26,61,0.35);
            }

            .card {
                background: linear-gradient(135deg, #1a1a3d 0%, #6b4f1f 100%);
            }

            .header-icon-link {
                color: #6b4f1f;
            }

            /* ---- FİLTRE FORMU ---- */
            .search-row {
                display: flex;
                gap: 14px;
                align-items: flex-end;
                flex-wrap: wrap;
            }

                .search-row .form-group {
                    flex: 1;
                    min-width: 160px;
                    margin-bottom: 0;
                }

                .search-row .ara-btn-group {
                    flex: 0 0 auto;
                }

            .sonuc-ozet {
                color: rgba(255,255,255,0.6);
                font-size: 13px;
                margin-bottom: 14px;
            }

            /* ---- RAPOR ŞERİDİ ---- */
            .report-strip {
                display: flex;
                flex-direction: column;
                gap: 6px;
                background: rgba(255,255,255,0.06);
                border: 1px solid rgba(255,255,255,0.15);
                border-radius: 10px;
                padding: 14px 16px;
                margin-bottom: 10px;
                cursor: pointer;
                transition: background 0.15s;
            }

                .report-strip:hover {
                    background: rgba(255,255,255,0.11);
                }

            .report-strip-top {
                display: flex;
                align-items: center;
                gap: 10px;
                flex-wrap: wrap;
            }

            .report-strip .tarih {
                color: rgba(255,255,255,0.4);
                font-size: 11.5px;
                margin-left: auto;
            }

            .report-strip-alt {
                color: rgba(255,255,255,0.65);
                font-size: 12.5px;
            }

            .report-strip-mesaj {
                color: rgba(255,255,255,0.85);
                font-size: 13px;
                line-height: 1.5;
                display: -webkit-box;
                -webkit-line-clamp: 2;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

            /* ---- TİP ROZETİ ---- */
            .tip-badge {
                display: inline-block;
                font-size: 11px;
                font-weight: 700;
                padding: 4px 12px;
                border-radius: 999px;
                letter-spacing: 0.3px;
                white-space: nowrap;
            }

                .tip-badge.tip-sikayet {
                    background: rgba(211,47,47,0.25);
                    color: #ff8a80;
                    border: 1px solid rgba(211,47,47,0.5);
                }

                .tip-badge.tip-talep {
                    background: rgba(33,150,243,0.2);
                    color: #90caf9;
                    border: 1px solid rgba(33,150,243,0.5);
                }

            /* ---- DURUM ROZETİ ---- */
            .durum-badge {
                display: inline-block;
                font-size: 11px;
                font-weight: 700;
                padding: 4px 12px;
                border-radius: 999px;
                letter-spacing: 0.3px;
                white-space: nowrap;
            }

                .durum-badge.beklemede {
                    background: rgba(255,213,79,0.15);
                    color: #ffd54f;
                    border: 1px solid rgba(255,213,79,0.4);
                }

                .durum-badge.inceleniyor {
                    background: rgba(144,202,249,0.15);
                    color: #90caf9;
                    border: 1px solid rgba(144,202,249,0.4);
                }

                .durum-badge.cozuldu {
                    background: rgba(129,199,132,0.15);
                    color: #81c784;
                    border: 1px solid rgba(129,199,132,0.4);
                }

                .durum-badge.reddedildi {
                    background: rgba(255,255,255,0.08);
                    color: rgba(255,255,255,0.5);
                    border: 1px solid rgba(255,255,255,0.2);
                }

            .comment-empty-hint {
                color: rgba(255,255,255,0.5);
                font-size: 13px;
                padding: 20px 2px;
                text-align: center;
            }

            /* ---- SAYFALAMA ---- */
            .sayfalama-row {
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 16px;
                margin-top: 18px;
            }

            .sayfalama-bilgi {
                color: rgba(255,255,255,0.65);
                font-size: 13px;
                min-width: 90px;
                text-align: center;
            }

            .secondary-btn {
                padding: 10px 18px;
                background: rgba(255,255,255,0.1);
                color: white;
                border: 1px solid rgba(255,255,255,0.25);
                border-radius: 8px;
                font-size: 13.5px;
                font-weight: bold;
                cursor: pointer;
                white-space: nowrap;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                gap: 6px;
            }

                .secondary-btn:hover:not(:disabled) {
                    background: rgba(255,255,255,0.18);
                }

                .secondary-btn:disabled {
                    background: rgba(255,255,255,0.04);
                    color: rgba(255,255,255,0.3);
                    border-color: rgba(255,255,255,0.08);
                    cursor: not-allowed;
                }

            .geri-btn {
                background: none;
                border: none;
                color: rgba(255,255,255,0.7);
                font-size: 13px;
                font-weight: 700;
                cursor: pointer;
                margin-bottom: 16px;
                padding: 0;
            }

                .geri-btn:hover {
                    color: white;
                }

            /* ---- RAPOR DETAY BAŞLIĞI ---- */
            .detay-header {
                display: flex;
                align-items: center;
                justify-content: space-between;
                flex-wrap: wrap;
                gap: 12px;
                margin-bottom: 6px;
            }

                .detay-header h2 {
                    border-bottom: none;
                    margin-bottom: 0;
                    padding-bottom: 0;
                }

            .detay-alt-bilgi {
                color: rgba(255,255,255,0.55);
                font-size: 13px;
                margin-bottom: 18px;
                line-height: 1.6;
            }

            .talep-mesaj-kutusu {
                background: rgba(255,255,255,0.05);
                border-radius: 8px;
                padding: 14px 16px;
                margin-bottom: 18px;
                color: rgba(255,255,255,0.88);
                font-size: 13.5px;
                line-height: 1.6;
                white-space: pre-wrap;
            }

            /* ---- HEDEF YORUM KUTUSU (Şikayet edilen yorum özeti) ---- */
            .hedef-yorum-kutusu {
                background: rgba(0,0,0,0.2);
                border-radius: 8px;
                padding: 14px 16px;
                margin-bottom: 18px;
            }

                .hedef-yorum-kutusu .hy-top {
                    display: flex;
                    align-items: baseline;
                    gap: 10px;
                    flex-wrap: wrap;
                    margin-bottom: 8px;
                }

                .hedef-yorum-kutusu .kitap-adi {
                    color: white;
                    font-weight: 700;
                    font-size: 14px;
                }

                .hedef-yorum-kutusu .kullanici-bilgi {
                    color: rgba(255,255,255,0.6);
                    font-size: 12.5px;
                }

                .hedef-yorum-kutusu .yildizlar {
                    color: #ffd54f;
                    font-size: 13px;
                    letter-spacing: 1px;
                }

                .hedef-yorum-kutusu .yorum-metni {
                    color: rgba(255,255,255,0.85);
                    font-size: 13.5px;
                    line-height: 1.5;
                    white-space: pre-wrap;
                    word-break: break-word;
                    margin-bottom: 12px;
                }

            .eylem-linkleri {
                display: flex;
                gap: 10px;
                flex-wrap: wrap;
            }

            .rapor-not-satiri {
                color: rgba(255,255,255,0.45);
                font-size: 11.5px;
                margin: -8px 0 14px 0;
                line-height: 1.5;
            }

            @@media (max-width: 720px) {
                .search-row {
                    flex-direction: column;
                    align-items: stretch;
                }
            }
    </style>
</head>
<body>
    <div class="admin-header">
        Admin Paneli — Talep/Şikayet Yönetimi
        <div class="header-icons">
            <a href="/Admin" class="header-icon-link" title="Admin Paneline Dön"><i class="fa-solid fa-user-pen"></i></a>
            <a href="/Bookland" class="header-icon-link" title="Bookland'e Git"><i class="fa-solid fa-house"></i></a>
        </div>
    </div>

    <div class="admin-body">

        <!-- LİSTE GÖRÜNÜMÜ -->
        <div id="listeGorunumu">

            <!-- FİLTRE -->
            <div class="card">
                <h2>🔎 Filtrele</h2>
                <div class="search-row">
                    <div class="form-group" style="max-width:180px;">
                        <label>Tip</label>
                        <select id="filtreTip">
                            <option value="all" selected>Tümü</option>
                            <option value="Şikayet">Şikayet</option>
                            <option value="Talep">Talep</option>
                        </select>
                    </div>
                    <div class="form-group" style="max-width:180px;">
                        <label>Durum</label>
                        <select id="filtreDurum">
                            <option value="all" selected>Tümü</option>
                            <option value="Beklemede">Beklemede</option>
                            <option value="İnceleniyor">İnceleniyor</option>
                            <option value="Çözüldü">Çözüldü</option>
                            <option value="Reddedildi">Reddedildi</option>
                        </select>
                    </div>
                    <div class="form-group ara-btn-group">
                        <button type="button" class="getir-btn" id="araBtn" onclick="ara()">
                            <span class="btn-label">🔎 Filtrele</span>
                        </button>
                    </div>
                </div>
            </div>

            <!-- SONUÇLAR -->
            <div class="card">
                <h2>📋 Talepler / Şikayetler</h2>
                <div class="sonuc-ozet" id="sonucOzet"></div>
                <div id="raporListesi"></div>

                <div class="sayfalama-row">
                    <button type="button" class="secondary-btn" id="oncekiBtn" onclick="sayfaDegistir(-1)">‹ Önceki</button>
                    <span class="sayfalama-bilgi" id="sayfaBilgisi">Sayfa 1 / 1</span>
                    <button type="button" class="secondary-btn" id="sonrakiBtn" onclick="sayfaDegistir(1)">Sonraki ›</button>
                </div>
            </div>

        </div>

        <!-- DETAY GÖRÜNÜMÜ -->
        <div id="detayGorunumu" style="display:none;">

            <button type="button" class="geri-btn" onclick="listeyeDon()">‹ Listeye Dön</button>

            <div class="card">
                <div class="detay-header">
                    <h2 id="detayBaslik">Rapor</h2>
                    <span class="durum-badge" id="detayDurumBadge"></span>
                </div>
                <div class="detay-alt-bilgi" id="detayAltBilgi"></div>

                <!-- TALEP: sadece mesaj -->
                <div id="talepMesajKutusu" style="display:none;">
                    <div class="talep-mesaj-kutusu" id="talepMesajMetni"></div>
                </div>

                <!-- ŞİKAYET: hedef yorum özeti + yönlendirme linkleri -->
                <div id="hedefYorumKutusu" style="display:none;">
                    <div class="hedef-yorum-kutusu">
                        <div class="hy-top">
                            <span class="kitap-adi" id="hyKitapAdi"></span>
                            <span class="kullanici-bilgi" id="hyKullaniciBilgi"></span>
                            <span class="yildizlar" id="hyYildizlar"></span>
                        </div>
                        <div class="yorum-metni" id="hyYorumMetni"></div>
                        <div class="eylem-linkleri">
                            <a class="secondary-btn" id="panel21Link" href="#">🔍 Yorum Yönetiminde İncele</a>
                            <a class="secondary-btn" id="panel22Link" href="#">⚖ Kullanıcı Yönetiminde Eylem Ekle</a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <h2>📝 Durumu Güncelle</h2>
                <div class="form-group">
                    <label>Durum</label>
                    <select id="durumSecimi">
                        <option value="Beklemede">Beklemede</option>
                        <option value="İnceleniyor">İnceleniyor</option>
                        <option value="Çözüldü">Çözüldü</option>
                        <option value="Reddedildi">Reddedildi</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>İç Not (sadece adminler görür)</label>
                    <textarea id="adminNotu" placeholder="Opsiyonel açıklama..."></textarea>
                </div>
                <div class="form-group">
                    <label>Kullanıcıya Gönderilecek Mesaj</label>
                    <textarea id="kullaniciMesaji" placeholder="Opsiyonel — kullanıcıya iletilecek yanıt..."></textarea>
                </div>
                <p class="rapor-not-satiri">Hazır mesaj şablonları ileride eklenecek — şimdilik serbest metin.</p>
                <button type="button" class="save-btn" onclick="raporGuncelle()">Kaydet</button>
            </div>

        </div>

    </div>

    <script src="~/js/admin/reportManagement.js"></script>
</body>
</html>