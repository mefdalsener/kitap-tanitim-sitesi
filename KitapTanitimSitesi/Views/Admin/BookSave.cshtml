@{
    ViewData["Title"] = "Kitap Ekle";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/css/admin-panel.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    <!--
        SAYFA TEMASI — Kitap Ekle (yeşil).
        admin-panel.css'teki .admin-header / .card / .popup-box için ortak lacivert
        gradient burada eziliyor (override). Admin Index'teki yeşil "Kitap Ekle"
        kartıyla aynı renk ailesi kullanılıyor, ama orijinal lacivert temayla aynı
        koyuluk/parlaklık seviyesinde tutuluyor — böylece card içindeki düşük
        opaklıklı (rgba(255,255,255,0.4-0.7)) etiket/placeholder yazıları da
        okunabilir kalıyor. Kaydet/Getir gibi işlem butonlarının yeşili kasıtlı
        olarak DEĞİŞTİRİLMEDİ — o renk tema değil, site genelinde tutarlı bir
        "aksiyon/onay" rengi.
    -->
    <style>
            .admin-header {
                background: linear-gradient(135deg, #0d2b21 0%, #1a5c3d 100%);
                box-shadow: 0 2px 12px rgba(13,43,33,0.35);
            }

            .card,
            .popup-box {
                background: linear-gradient(135deg, #0d2b21 0%, #1a5c3d 100%);
            }

            .header-icon-link {
                color: #1a5c3d;
            }

            /* ISBN zaten kayıtlı UYARI POPUP'I — arka plan .popup-box ile aynı (yukarıdaki
                           gradient override'ı otomatik alır), sadece overlay + kutu boyutlandırması burada. */
            .isbn-uyari-overlay {
                display: none;
                position: fixed;
                inset: 0;
                background: rgba(0,0,0,0.6);
                z-index: 999;
                align-items: center;
                justify-content: center;
            }

                .isbn-uyari-overlay.active {
                    display: flex;
                }

            .isbn-uyari-box {
                max-width: 460px;
                width: 90%;
                padding: 26px 28px;
                border-radius: 14px;
                box-shadow: 0 10px 36px rgba(0,0,0,0.5);
                position: relative;
                color: #fff;
            }

                .isbn-uyari-box h2 {
                    margin: 0 0 10px 0;
                    font-size: 19px;
                    color: #ffb74d;
                }

                .isbn-uyari-box p {
                    margin: 0 0 10px 0;
                    line-height: 1.6;
                    font-size: 14px;
                    color: rgba(255,255,255,0.85);
                }

            .isbn-uyari-mesaj {
                background: rgba(255,255,255,0.08);
                border-left: 3px solid #ffb74d;
                padding: 10px 12px;
                border-radius: 6px;
                font-size: 13.5px;
                line-height: 1.6;
            }

                .isbn-uyari-mesaj a {
                    color: #90caf9;
                    text-decoration: underline;
                    font-weight: 600;
                }

            .isbn-uyari-actions {
                margin-top: 20px;
                display: flex;
                gap: 10px;
                justify-content: flex-end;
            }

            .isbn-uyari-close {
                position: absolute;
                top: 8px;
                right: 12px;
                background: none;
                border: none;
                color: rgba(255,255,255,0.6);
                font-size: 20px;
                line-height: 1;
                cursor: pointer;
            }

                .isbn-uyari-close:hover {
                    color: #fff;
                }

            .scrape-links-toggle,
            .scrape-links-panel {
                background: linear-gradient(135deg, #0d2b21 0%, #1a5c3d 100%);
            }
    </style>
</head>
<body>
    <div class="admin-header">
        Admin Paneli — Kitap Ekle
        <div class="header-icons">
            <a href="/Admin" class="header-icon-link" title="Admin Paneline Dön"><i class="fa-solid fa-user-pen"></i></a>
            <a href="/Bookland" class="header-icon-link" title="Bookland'e Git"><i class="fa-solid fa-house"></i></a>
        </div>
    </div>
    <!-- SOL KAYAN KAYNAK LİNK PANELİ (scrape edilen linkler) -->
    <div class="scrape-links-widget" id="scrapeLinksWidget">
        <div class="scrape-links-toggle" id="scrapeLinksToggle" onclick="scrapeLinksPaneliAcKapat(event)" title="Kaynak Linkleri">
            <i class="fa-solid fa-list"></i>
        </div>
        <div class="scrape-links-panel" id="scrapeLinksPanel">
            <div class="scrape-links-section" id="scrapeLinksBookSection" style="display:none;">
                <h4>Kitap Bilgileri</h4>
                <a id="scrapeLinkKitapyurdu" href="#" target="_blank" rel="noopener" style="display:none;">
                    <i class="fa-solid fa-book"></i><span>Kitapyurdu Linki</span>
                </a>
                <a id="scrapeLinkGoodreadsBook" href="#" target="_blank" rel="noopener" style="display:none;">
                    <i class="fa-brands fa-goodreads"></i><span>Goodreads Linki</span>
                </a>
            </div>
            <div class="scrape-links-section" id="scrapeLinksAuthorSection" style="display:none;">
                <h4>Yazar Bilgileri</h4>
                <div id="scrapeLinksAuthorList"></div>
            </div>
            <div class="scrape-links-empty" id="scrapeLinksEmpty">Henüz link yok. Önce "Getir" ile veri çekin.</div>
        </div>
    </div>
    <div class="admin-body">

        <!-- OTOMATİK VERİ ÇEKME KARTI (BookSave'e özgü — partial'da DEĞİL) -->
        <div class="card" id="scrapePaneli">
            <h2>🔗 Kitapyurdu ve Goodreads Linklerinden Otomatik Doldur</h2>

            <div class="scrape-input-group">
                <label>Kitapyurdu Linki</label>
                <input type="text" id="kitapyurduUrl" placeholder="https://www.kitapyurdu.com/kitap/..." />
            </div>

            <div class="scrape-input-group">
                <label>Goodreads Linki</label>
                <input type="text" id="goodreadsUrl" placeholder="https://www.goodreads.com/book/show/..." />
            </div>

            <div class="scrape-bottom-row">
                <button class="getir-btn" id="getirBtn" onclick="getirVeDoldur()">
                    <span class="spinner"></span>
                    <span class="btn-label">⬇ Getir</span>
                </button>
                <button type="button" class="getir-btn" id="linkTemizleBtn" style="background:#555;" onclick="linkleriTemizle()" title="Link kutularını ve doldurulan ISBN'i temizle">
                    <span class="btn-label">✕ Temizle</span>
                </button>
            </div>

            <span id="getirDurum"></span>
            <div id="eslesmeSonuclari" style="margin-top:8px; font-size:13px; color:#81c784; line-height:1.6;"></div>

            <!-- ISBN artık elle girilip aranmıyor — sadece link ile "Getir" sonucunda otomatik dolar. -->
            <!-- ISBN hem linkten (scrape) otomatik dolabilir hem de elle girilip düzenlenebilir. -->
            <div class="scrape-isbn-group" style="margin-top:14px;">
                <label>ISBN</label>
                <input type="text" id="isbnInput" placeholder="Linkten otomatik dolar, ya da elle girin..." onchange="isbnKayitliKontrolEt()" />
            </div>
            <span id="isbnDurum" style="display:block; margin-top:8px; font-size:13px; color:rgba(255,255,255,0.75); min-height:18px;"></span>
        </div>

        <!-- ORTAK FORM GÖVDESİ (kitap bilgileri, çevirmen, yazar, popup'lar) -->
        <!-- ISBN veritabanında zaten kayıtlıysa bookFormArea içindeki TÜM alanlar ve Kaydet butonu kilitlenir. -->
        <div id="bookFormArea">
            @await Html.PartialAsync("_BookFormPartial")

            <!-- KAYDET (her sayfa kendi metnini/id'sini kendi .cshtml'inde tutar) -->
            <button class="save-btn" id="saveBtn" onclick="kaydet()">💾 Kaydet</button>
        </div>

    </div>

    <!-- ISBN zaten kayıtlı UYARI POPUP'I -->
    <div class="isbn-uyari-overlay" id="isbnUyariOverlay">
        <div class="card isbn-uyari-box" id="isbnUyariBox">
            <button type="button" class="isbn-uyari-close" onclick="isbnUyariKapat()" title="Kapat">✕</button>
            <h2>⚠ Bu kitap zaten var.</h2>
            <p>İsterseniz düzenleyebilirsiniz:</p>
            <div class="isbn-uyari-mesaj" id="isbnUyariMesaj"></div>
            <div class="isbn-uyari-actions">
                <button type="button" class="getir-btn" style="background:#555;" onclick="isbnUyariTemizle()">
                    <span class="btn-label">✕ Temizle</span>
                </button>
                <a id="isbnUyariLink" href="#" class="save-btn" style="text-decoration:none; display:inline-flex; align-items:center;">Düzenlemeye Git</a>
            </div>
        </div>
    </div>

    <!--
        Script yükleme sırası KRİTİK: bookFormCommon.js önce gelmeli, çünkü
        _BookFormPartial'daki onclick/onchange handler'ları (popupAc, cevirmenEkle,
        yazarEkle, checkSeriesOrderConflict, onCoverUrlChange...) o dosyada tanımlı.
        bookSave.js ise sadece bu sayfaya özgü fonksiyonları (getirVeDoldur, isbnKayitliKontrolEt,
        kaydet, resetForm) içerir ve bookFormCommon.js'teki fonksiyonlara bağımlıdır.
    -->
    <script src="~/js/admin/bookFormCommon.js"></script>
    <script src="~/js/admin/bookSave.js"></script>
</body>
</html>
