@{
	ViewData["Title"] = "Yorum Yönetimi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
	<meta charset="utf-8" />
	<title>@ViewData["Title"]</title>
	<link rel="stylesheet" href="~/css/admin-panel.css" />
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
	<!--
        Aşağıdaki stiller SADECE bu sayfaya özgü (yorum şeridi görünümü, silinmiş
        yorum stili, sayfalama). admin-panel.css'e eklenmedi — SeriesEdit'teki
        aynı gerekçe: paylaşılan dosyanın gerçek içeriğini büyütmemek için
        sayfa-özel olan her şey burada tutuluyor.
    -->
	<style>
			/* ---- SAYFA TEMASI — Yorum Yönetimi (bordo/kırmızı).
																	   Diğer panellerden (yeşil/turuncu/mavi/mor) ayrışsın diye —
																	   moderasyon/silme temalı bir renk. ---- */
			.admin-header {
				background: linear-gradient(135deg, #3a0000 0%, #7a0c1f 100%);
				box-shadow: 0 2px 12px rgba(58,0,0,0.35);
			}

			.card,
			.popup-box {
				background: linear-gradient(135deg, #3a0000 0%, #7a0c1f 100%);
			}

			.header-icon-link {
				color: #7a0c1f;
			}

			/* ---- ARAMA FORMU — 4 alan yan yana ---- */
			.search-row {
				display: flex;
				gap: 14px;
				align-items: flex-end;
				flex-wrap: wrap;
			}

				.search-row .form-group {
					flex: 1;
					min-width: 160px;
					margin-bottom: 0;
				}

				.search-row .ara-btn-group {
					flex: 0 0 auto;
				}

			/* ---- SONUÇ ÖZETİ ---- */
			.sonuc-ozet {
				color: rgba(255,255,255,0.6);
				font-size: 13px;
				margin-bottom: 14px;
			}

			/* ---- YORUM ŞERİDİ ---- */
			.comment-strip {
				display: flex;
				gap: 16px;
				background: rgba(255,255,255,0.06);
				border: 1px solid rgba(255,255,255,0.15);
				border-radius: 10px;
				padding: 14px 16px;
				margin-bottom: 10px;
			}

				.comment-strip.deleted {
					opacity: 0.55;
					border-style: dashed;
				}

			.comment-strip-cover {
				width: 46px;
				height: 68px;
				flex-shrink: 0;
				border-radius: 6px;
				overflow: hidden;
				background: rgba(255,255,255,0.08);
				display: flex;
				align-items: center;
				justify-content: center;
			}

				.comment-strip-cover img {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}

				.comment-strip-cover .placeholder {
					font-size: 9px;
					color: rgba(255,255,255,0.4);
					text-align: center;
				}

			.comment-strip-body {
				flex: 1;
				min-width: 0;
			}

			.comment-strip-top {
				display: flex;
				align-items: baseline;
				gap: 10px;
				flex-wrap: wrap;
				margin-bottom: 4px;
			}

			.comment-strip .kitap-adi {
				color: white;
				font-weight: 700;
				font-size: 14.5px;
			}

			.comment-strip .kullanici-bilgi {
				color: rgba(255,255,255,0.6);
				font-size: 12.5px;
			}

			.comment-strip .yildizlar {
				color: #ffd54f;
				font-size: 13px;
				letter-spacing: 1px;
			}

			.comment-strip .tarih {
				color: rgba(255,255,255,0.4);
				font-size: 11.5px;
				margin-left: auto;
			}

			.comment-strip .yorum-metni {
				color: rgba(255,255,255,0.88);
				font-size: 13.5px;
				line-height: 1.5;
				white-space: pre-wrap;
				word-break: break-word;
			}

				/* ---- UZUN YORUMLAR — varsayılan 5 satırla sınırlı, "Devamını Göster"
								   ile açılıyor. Buton, sadece yorum gerçekten 5 satırı aşıyorsa
								   JS tarafından görünür yapılıyor (yorumListesiRenderEt sonrası
								   scrollHeight/clientHeight karşılaştırması). ---- */
				.comment-strip .yorum-metni.clamp {
					display: -webkit-box;
					-webkit-line-clamp: 5;
					-webkit-box-orient: vertical;
					overflow: hidden;
				}

					.comment-strip .yorum-metni.clamp.genisletilmis {
						display: block;
						-webkit-line-clamp: unset;
						overflow: visible;
					}

			.devam-toggle-btn {
				display: none;
				margin-top: 6px;
				background: none;
				border: none;
				color: #ff8a80;
				font-size: 12px;
				font-weight: 700;
				cursor: pointer;
				padding: 0;
			}

				.devam-toggle-btn:hover {
					text-decoration: underline;
				}

			.comment-strip .durum-badge {
				display: inline-block;
				font-size: 11px;
				font-weight: 700;
				padding: 3px 10px;
				border-radius: 999px;
				letter-spacing: 0.3px;
			}

				.comment-strip .durum-badge.silinmis {
					background: rgba(211,47,47,0.25);
					color: #ff8a80;
					border: 1px solid rgba(211,47,47,0.5);
				}

			.silinmis-detay {
				margin-top: 8px;
				padding: 8px 10px;
				background: rgba(0,0,0,0.2);
				border-radius: 6px;
				font-size: 12px;
				color: rgba(255,255,255,0.6);
				line-height: 1.6;
			}

				.silinmis-detay .flagged-text {
					color: #ffab91;
					white-space: pre-wrap;
				}

			.comment-strip-actions {
				flex-shrink: 0;
				display: flex;
				align-items: flex-start;
			}

			.sil-btn {
				padding: 8px 16px;
				background: #d32f2f;
				color: white;
				border: none;
				border-radius: 8px;
				font-size: 12.5px;
				font-weight: 700;
				cursor: pointer;
				white-space: nowrap;
				transition: background 0.15s;
			}

				.sil-btn:hover {
					background: #b71c1c;
				}

			.comment-empty-hint {
				color: rgba(255,255,255,0.5);
				font-size: 13px;
				padding: 20px 2px;
				text-align: center;
			}

			/* ---- SAYFALAMA ---- */
			.sayfalama-row {
				display: flex;
				align-items: center;
				justify-content: center;
				gap: 16px;
				margin-top: 18px;
			}

				.sayfalama-row .secondary-btn:disabled {
					background: rgba(255,255,255,0.04);
					color: rgba(255,255,255,0.3);
					border-color: rgba(255,255,255,0.08);
					cursor: not-allowed;
				}

			.sayfalama-bilgi {
				color: rgba(255,255,255,0.65);
				font-size: 13px;
				min-width: 90px;
				text-align: center;
			}

			.secondary-btn {
				padding: 10px 18px;
				background: rgba(255,255,255,0.1);
				color: white;
				border: 1px solid rgba(255,255,255,0.25);
				border-radius: 8px;
				font-size: 13.5px;
				font-weight: bold;
				cursor: pointer;
				white-space: nowrap;
			}

				.secondary-btn:hover:not(:disabled) {
					background: rgba(255,255,255,0.18);
				}

			.popup-message {
				color: rgba(255,255,255,0.85);
				font-size: 14px;
				line-height: 1.5;
				margin: 4px 0 14px;
			}

			.popup-box textarea {
				width: 100%;
				padding: 11px 14px;
				border: 1px solid rgba(255,255,255,0.2);
				border-radius: 8px;
				font-size: 13.5px;
				font-family: Arial, sans-serif;
				margin-bottom: 6px;
				background: rgba(255,255,255,0.08);
				color: white;
				resize: vertical;
				min-height: 70px;
			}

				.popup-box textarea::placeholder {
					color: rgba(255,255,255,0.4);
				}

				.popup-box textarea:focus {
					outline: none;
					background: rgba(255,255,255,0.14);
					border-color: #d32f2f;
				}

			.popup-hint {
				font-size: 11.5px;
				color: rgba(255,255,255,0.45);
				margin-bottom: 16px;
				line-height: 1.5;
			}

			.btn-danger {
				background: #d32f2f !important;
			}

				.btn-danger:hover {
					background: #b71c1c !important;
				}

			@@media (max-width: 720px) {
				.search-row {
					flex-direction: column;
					align-items: stretch;
				}

				.comment-strip {
					flex-wrap: wrap;
				}

				.comment-strip-actions {
					width: 100%;
					justify-content: flex-end;
				}
			}
	</style>
</head>
<body>
	<div class="admin-header">
		Admin Paneli — Yorum Yönetimi
		<div class="header-icons">
			<a href="/Admin" class="header-icon-link" title="Admin Paneline Dön"><i class="fa-solid fa-user-pen"></i></a>
			<a href="/Bookland" class="header-icon-link" title="Bookland'e Git"><i class="fa-solid fa-house"></i></a>
		</div>
	</div>

	<div class="admin-body">
		<!-- ---- YENİ (Faz Ekstra 2.3): Report panelinden ?ratingId=X ile
             gelindiğinde ilgili yorumu üstte pinler. Mevcut aramaya karışmaz,
             ayrı bir kart. ---- -->
		<div class="card" id="pinliYorumKarti" style="display:none;">
			<h2>🔗 Rapor Üzerinden İncelenen Yorum</h2>
			<div id="pinliYorumIcerik"></div>
		</div>
		<!-- ARAMA -->
		<div class="card">
			<h2>🔎 Yorum Ara</h2>
			<div class="search-row">
				<div class="form-group">
					<label>Kitap Adı</label>
					<input type="text" id="aramaKitapAdi" placeholder="Örn: Kürk Mantolu Madonna" />
				</div>
				<div class="form-group">
					<label>Kullanıcı Adı</label>
					<input type="text" id="aramaKullaniciAdi" placeholder="Kullanıcı adı..." />
				</div>
				<div class="form-group" style="max-width:160px;">
					<label>Kullanıcı Kimliği</label>
					<input type="text" id="aramaKullaniciPublicId" placeholder="Örn: 260000123" maxlength="9" />
				</div>
				<div class="form-group" style="max-width:170px;">
					<label>Durum</label>
					<select id="aramaDurum">
						<option value="all" selected>Tümü</option>
						<option value="active">Sadece Aktif</option>
						<option value="deleted">Sadece Silinmiş</option>
					</select>
				</div>
				<div class="form-group ara-btn-group">
					<button type="button" class="getir-btn" id="araBtn" onclick="ara()">
						<span class="btn-label">🔎 Ara</span>
					</button>
				</div>
			</div>
		</div>

		<!-- SONUÇLAR -->
		<div class="card">
			<h2>💬 Yorumlar</h2>
			<div class="sonuc-ozet" id="sonucOzet"></div>
			<div id="yorumListesi"></div>

			<div class="sayfalama-row">
				<button type="button" class="secondary-btn" id="oncekiBtn" onclick="sayfaDegistir(-1)">‹ Önceki</button>
				<span class="sayfalama-bilgi" id="sayfaBilgisi">Sayfa 1 / 1</span>
				<button type="button" class="secondary-btn" id="sonrakiBtn" onclick="sayfaDegistir(1)">Sonraki ›</button>
			</div>
		</div>

	</div>

	<!-- POPUP: Yorumu Sil (onay + hakaret işaretleme) -->
	<div class="popup-overlay" id="popupYorumSil">
		<div class="popup-box">
			<h3>Yorumu Sil</h3>
			<p id="yorumSilMesaji" class="popup-message"></p>
			<textarea id="flaggedTextInput" placeholder="Hakaretli/uygunsuz ifade(ler) varsa buraya yazın (her satıra bir tane) — opsiyonel"></textarea>
			<p class="popup-hint">Bu alan, ileride kullanıcının ceza geçmişinde ilgili ifadeleri vurgulamak için kullanılacak. Boş bırakabilirsiniz.</p>
			<div class="popup-buttons">
				<button class="btn-cancel" onclick="popupKapat('yorumSil')">İptal</button>
				<button class="btn-confirm btn-danger" onclick="yorumSilOnayla()">Yorumu Sil</button>
			</div>
		</div>
	</div>

	<script src="~/js/admin/commentModeration.js"></script>
</body>
</html>
