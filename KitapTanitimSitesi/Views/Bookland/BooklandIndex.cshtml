@model KitapTanitimSitesi.Models.ViewModels.BooklandViewModel

@{
	ViewData["Title"] = "Bookland";

	// Kitapları Türkçe alfabetik sıraya göre diz ve popup / seri mantığı için
	// gerekli tüm bilgiyi tek seferde JSON'a hazır hale getir.
	var trCulture = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
	var siraliKitaplar = Model.Books
		.OrderBy(b => b.BookName, StringComparer.Create(trCulture, ignoreCase: true))
		.ToList();

	var kitapVerileri = siraliKitaplar.Select(kitap => new
	{
		id = kitap.BookID,
		ad = kitap.BookName,
		kapak = kitap.BookCoverImage_URL ?? "",
		yazar = string.Join(", ", kitap.BookAuthors.Select(ba => ba.Author.AuthorName + " " + ba.Author.AuthorSurname)),
		yazarIds = kitap.BookAuthors.Select(ba => ba.AuthorID).ToList(),
		yazarListesi = kitap.BookAuthors.Select(ba => new { id = ba.AuthorID, ad = ba.Author.AuthorName + " " + ba.Author.AuthorSurname }).ToList(),
		yayinevi = string.Join(", ", kitap.BookPublishers.Select(bp => bp.Publisher.PublisherName)),
		yayineviIds = kitap.BookPublishers.Select(bp => bp.PublisherID).ToList(),
		ilkYil = kitap.FirstPublishYear.HasValue ? kitap.FirstPublishYear.Value.ToString() : "",
		basimYili = string.Join(", ", kitap.BookPublishers.Select(bp => bp.PublishYear.HasValue ? bp.PublishYear.Value.ToString() : "")),
		sayfa = string.Join(", ", kitap.BookPublishers.Select(bp => bp.PageCount.HasValue ? bp.PageCount.Value.ToString() : "")),
		sayfaSayilari = kitap.BookPublishers.Where(bp => bp.PageCount.HasValue).Select(bp => bp.PageCount.Value).ToList(),
		tur = string.Join(", ", kitap.BookGenres.Select(bg => bg.Genre.GenreName)),
		turIds = kitap.BookGenres.Select(bg => bg.GenreID).ToList(),
		cevirmen = string.Join(", ", kitap.BookTranslators.Select(bt => bt.Translator.TranslatorName + " " + bt.Translator.TranslatorSurname)),
		cevirmenIds = kitap.BookTranslators.Select(bt => bt.TranslatorID).ToList(),
		aciklama = kitap.BookDescription ?? "",
		seriesId = kitap.SeriesID,
		seriesOrder = kitap.SeriesOrder
	}).ToList();

	// Filtre panelinde SADECE gerçekten en az bir kitapta kullanılan
	// yazar / yayınevi / çevirmen / tür / seri seçeneklerinin görünmesi için
	// kullanılan ID'lerin kümesini çıkarıyoruz. Böylece SQL tablosunda kayıtlı
	// ama hiçbir kitapta olmayan bir tür (örn. "Anı") filtre listesinde görünmez.
	var kullanilanYazarIdleri = kitapVerileri.SelectMany(k => k.yazarIds).Distinct().ToHashSet();
	var kullanilanYayineviIdleri = kitapVerileri.SelectMany(k => k.yayineviIds).Distinct().ToHashSet();
	var kullanilanCevirmenIdleri = kitapVerileri.SelectMany(k => k.cevirmenIds).Distinct().ToHashSet();
	var kullanilanTurIdleri = kitapVerileri.SelectMany(k => k.turIds).Distinct().ToHashSet();
	var kullanilanSeriIdleri = kitapVerileri
		.Where(k => k.seriesId != null)
		.Select(k => (int)k.seriesId)
		.Distinct()
		.ToHashSet();

	var tumSayfaSayilari = siraliKitaplar
	.SelectMany(k => k.BookPublishers)
	.Where(bp => bp.PageCount.HasValue)
	.Select(bp => bp.PageCount.Value)
	.ToList();

	var sayfaMinDeger = tumSayfaSayilari.Any() ? (tumSayfaSayilari.Min() / 10) * 10 : 0;
	var sayfaMaxDeger = tumSayfaSayilari.Any() ? ((tumSayfaSayilari.Max() / 10) + 1) * 10 : 2000;

	var kitapVerileriJson = System.Text.Json.JsonSerializer.Serialize(kitapVerileri);
	var kitapVerileriMap = kitapVerileri.ToDictionary(k => k.id);

	// Yazarları Türkçe alfabetik sıraya göre diz (Ad Soyad) ve popup'ta
	// gösterilecek/istemci tarafında kullanılacak tüm bilgiyi tek seferde JSON'a hazırla.
	// Not: Yazar -> Kitap ilişkisi ayrı bir sorgu ile değil, kitap verisinde zaten
	// var olan yazarIds alanı üzerinden (ters yönde) istemci tarafında kuruluyor —
	// tıpkı seri/ilgili kitaplar mantığında olduğu gibi, ekstra sorgu gerekmiyor.
	var siraliYazarlar = Model.Authors
		.OrderBy(a => a.AuthorName + " " + a.AuthorSurname, StringComparer.Create(trCulture, ignoreCase: true))
		.ToList();

	var yazarVerileri = siraliYazarlar.Select(yazar => new
	{
		id = yazar.AuthorID,
		ad = yazar.AuthorName + " " + yazar.AuthorSurname,
		foto = yazar.AuthorImage_URL ?? "",
		dogumYili = yazar.AuthorBirthYear,
		olumYili = yazar.AuthorDeathYear,
		aciklama = yazar.AuthorBiography ?? ""
	}).ToList();

	var yazarVerileriJson = System.Text.Json.JsonSerializer.Serialize(yazarVerileri);

}

<!DOCTYPE html>
<html lang="tr">
<head>
	<meta charset="utf-8" />
	<title>@ViewData["Title"]</title>
	<link rel="stylesheet" href="~/css/site.css" />

	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Rakkas&family=Sacramento&family=Special+Elite&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="~/css/bookland.css" />
	
</head>
<body>

	<!-- ÜST BAR -->
	<header class="top-bar">
		<div class="top-bar-left">
			<div class="site-name">
				<a asp-controller="Bookland" asp-action="Index">
					<img src="~/images/med-logo-1.png" alt="Logo" style="height: 40px; object-fit: contain;" />
				</a>
			</div>

			<nav class="nav-buttons">
				<button id="btn-kitaplar" class="nav-btn active">Kitaplar</button>
				<button id="btn-yazarlar" class="nav-btn">Yazarlar</button>
			</nav>
		</div>

		<div class="auth-buttons">
			@if (!User.Identity.IsAuthenticated)
			{
				<a class="auth-btn auth-btn-ghost" asp-controller="Account" asp-action="Login">Giriş Yap</a>
				<a class="auth-btn auth-btn-solid" asp-controller="Account" asp-action="Register">Kayıt Ol</a>
			}
			else
			{
				<div class="kullanici-dropdown" id="kullanici-dropdown">
					<span class="auth-btn auth-btn-ghost kullanici-toggle" id="kullanici-toggle">
						@User.Identity.Name
					</span>
					<div class="kullanici-menu" id="kullanici-menu">
						@if (User.IsInRole("admin"))
						{
							<a href="https://localhost:7129/Admin/" class="kullanici-menu-item">Admin Paneli</a>
						}
						<form asp-controller="Account" asp-action="Logout" method="post">
							@Html.AntiForgeryToken()
							<button type="submit" class="kullanici-menu-item">Çıkış Yap</button>
						</form>
					</div>
				</div>
			}
		</div>
	</header>

	<!-- ANA İÇERİK -->
	<div class="content-wrapper">

		<!-- KİTAPLAR GÖRÜNÜMÜ -->
		<div id="view-kitaplar" class="view-section active">

			<aside class="filter-area">
				<input type="text" id="kitap-arama-input" class="book-search-input"
					   placeholder="🔍 Kitap ara..." oninput="kitapAramaGirisDegisti(this.value)" onchange="kitapAramaDurumunuURLyeYaz(this.value)" />
				<div class="filter-reset-bar">
					<span class="filter-reset-baslik">Filtreler</span>
					<button class="filter-reset-btn" onclick="filtreleriSifirla()">Filtreleri Temizle</button>
				</div>
				<div class="filter-box">

					<!-- YAZAR FİLTRESİ -->
					<div class="filter-item" id="filter-yazar">
						<div class="filter-header" onclick="toggleFilter('yazar')">
							<span>Yazar</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-yazar">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('yazar', this.value)" />
							<div class="filter-list" id="list-yazar">
								@foreach (var author in Model.Authors.Where(a => kullanilanYazarIdleri.Contains(a.AuthorID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@author.AuthorID" onchange="filtreDegisti()" />
										@author.AuthorName @author.AuthorSurname
									</label>
								}
							</div>
						</div>
					</div>

					<!-- YAYINEVİ FİLTRESİ -->
					<div class="filter-item" id="filter-yayinevi">
						<div class="filter-header" onclick="toggleFilter('yayinevi')">
							<span>Yayınevi</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-yayinevi">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('yayinevi', this.value)" />
							<div class="filter-list" id="list-yayinevi">
								@foreach (var publisher in Model.Publishers.Where(p => kullanilanYayineviIdleri.Contains(p.PublisherID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@publisher.PublisherID" onchange="filtreDegisti()" />
										@publisher.PublisherName
									</label>
								}
							</div>
						</div>
					</div>

					<!-- ÇEVİRMEN FİLTRESİ -->
					<div class="filter-item" id="filter-cevirmen">
						<div class="filter-header" onclick="toggleFilter('cevirmen')">
							<span>Çevirmen</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-cevirmen">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('cevirmen', this.value)" />
							<div class="filter-list" id="list-cevirmen">
								@foreach (var translator in Model.Translators.Where(t => kullanilanCevirmenIdleri.Contains(t.TranslatorID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@translator.TranslatorID" onchange="filtreDegisti()" />
										@translator.TranslatorName @translator.TranslatorSurname
									</label>
								}
							</div>
						</div>
					</div>

					<!-- SERİ FİLTRESİ -->
					<div class="filter-item" id="filter-seri">
						<div class="filter-header" onclick="toggleFilter('seri')">
							<span>Seri</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-seri">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('seri', this.value)" />
							<div class="filter-list" id="list-seri">
								@foreach (var seri in Model.SeriesList.Where(s => kullanilanSeriIdleri.Contains(s.SeriesID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@seri.SeriesID" onchange="filtreDegisti()" />
										@seri.SeriesName
									</label>
								}
							</div>
						</div>
					</div>

					<!-- TÜR FİLTRESİ -->
					<div class="filter-item" id="filter-tur">
						<div class="filter-header" onclick="toggleFilter('tur')">
							<span>Tür</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-tur">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('tur', this.value)" />
							<div class="filter-list" id="list-tur">
								@foreach (var tur in Model.Genres.Where(g => kullanilanTurIdleri.Contains(g.GenreID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@tur.GenreID" onchange="filtreDegisti()" />
										@tur.GenreName
									</label>
								}
							</div>
						</div>
					</div>

					<!-- SAYFA SAYISI FİLTRESİ -->
					<div class="filter-item" id="filter-sayfa">
						<div class="filter-header" onclick="toggleFilter('sayfa')">
							<span>Sayfa Sayısı</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-sayfa">
							<div class="range-labels">
								<span id="range-min-label">@sayfaMinDeger</span>
								<span id="range-max-label">@sayfaMaxDeger</span>
							</div>
							<div class="range-container">
								<input type="range" id="range-min" min="@sayfaMinDeger" max="@sayfaMaxDeger" value="@sayfaMinDeger" step="10" oninput="rangeGuncelle()" onchange="rangeDurumunuURLyeYaz()" />
								<input type="range" id="range-max" min="@sayfaMinDeger" max="@sayfaMaxDeger" value="@sayfaMaxDeger" step="10" oninput="rangeGuncelle()" onchange="rangeDurumunuURLyeYaz()" />
							</div>
						</div>
					</div>

				</div>
			</aside>

			<main class="book-grid" id="book-grid">
				@foreach (var kitap in siraliKitaplar)
				{
					var veri = kitapVerileriMap[kitap.BookID];
					<div class="book-card" onclick="popupAc(kitapMap[@kitap.BookID])" style="cursor:pointer;">
						<div class="book-cover">
							@if (!string.IsNullOrEmpty(kitap.BookCoverImage_URL))
							{
								<img src="@kitap.BookCoverImage_URL" alt="@kitap.BookName" />
							}
						</div>
						<div class="book-information">
							<p class="book-title">@kitap.BookName</p>
							<p class="book-author">@veri.yazar</p>
							<p class="book-publisher">@veri.yayinevi</p>
						</div>
					</div>
				}
			</main>

			<div class="arama-bos-durum" id="arama-bos-durum">
				<img src="~/images/little-dragon-in-library.png" alt="Kitap bulunamadı" />
				<p class="arama-bos-yazi" id="arama-bos-yazi"></p>
			</div>

		</div>

		<!-- YAZARLAR GÖRÜNÜMÜ -->
		<div id="view-yazarlar" class="view-section">
			<div class="author-area">
				<div class="author-search-bar">
					<input type="text" id="yazar-arama-input" class="author-search-input"
						   placeholder="🔍 Yazar ara..." oninput="yazarAramaGirisDegisti(this.value)" onchange="yazarAramaDurumunuURLyeYaz(this.value)" />
				</div>
				<main class="author-grid" id="author-grid">
					@foreach (var yazar in siraliYazarlar)
					{
						<div class="author-card" onclick="yazarPopupAc(yazarMap[@yazar.AuthorID])" style="cursor:pointer;">
							<div class="author-cover">
								@if (!string.IsNullOrEmpty(yazar.AuthorImage_URL))
								{
									<img src="@yazar.AuthorImage_URL" alt="@yazar.AuthorName @yazar.AuthorSurname" />
								}
							</div>
							<div class="author-information">
								<p class="author-name">@yazar.AuthorName @yazar.AuthorSurname</p>
								<p class="author-lifespan">
									@if (yazar.AuthorBirthYear.HasValue)
									{
										@(yazar.AuthorBirthYear + " – " + (yazar.AuthorDeathYear.HasValue ? yazar.AuthorDeathYear.Value.ToString() : "Hayatta"))
									}
								</p>
								<p class="author-bio-preview">@yazar.AuthorBiography</p>
							</div>
						</div>
					}
				</main>
			</div>
		</div>

	</div>

	<!-- KİTAP POPUP -->
	<div id="kitap-popup-overlay" class="popup-overlay" onclick="popupKapat()">
		<div id="kitap-popup" class="popup-modal" onclick="event.stopPropagation()">

			@if (User.IsInRole("admin"))
			{
				<button class="popup-duzenle" onclick="kitapDuzenle()" title="Bu kitabı düzenle">✎</button>
			}
			<button class="popup-kapat" onclick="popupKapat()">✕</button>

			<div class="popup-icerik">

				<!-- Sol: sadece kapak (yükseklik sabit, genişlik kapağın kendi oranına göre dinamik) -->
				<div class="popup-sol">
					<div class="popup-kapak">
						<img id="popup-kapak-img" src="" alt="" />
					</div>
				</div>

				<!-- Sağ: üstte sabit başlık alanı, altta kaydırılabilir gövde -->
				<div class="popup-sag">

					<div class="popup-sag-sabit">
						<h2 id="popup-kitap-adi" class="popup-baslik"></h2>
						<div class="popup-yazar-yayinevi">
							<p id="popup-yazar" class="popup-yazar-adi"></p>
							<p id="popup-yayinevi" class="popup-yayinevi-adi"></p>
						</div>
					</div>

					<div class="popup-sag-kaydirilabilir" id="popup-scroll-alani">

						<div class="popup-bilgiler">
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">İlk Yayın Yılı</span>
								<span id="popup-ilk-yil"></span>
							</div>
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">Basım Yılı</span>
								<span id="popup-basim-yili"></span>
							</div>
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">Sayfa Sayısı</span>
								<span id="popup-sayfa"></span>
							</div>
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">Tür</span>
								<span id="popup-tur"></span>
							</div>
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">Çevirmen</span>
								<span id="popup-cevirmen"></span>
							</div>
						</div>

						<div class="popup-aciklama">
							<p id="popup-aciklama-metin"></p>
						</div>

						<!-- Seri / ilgili kitaplar bölümü: sadece kitap bir seriye bağlıysa görünür -->
						<div class="popup-seri" id="popup-seri"></div>

					</div>

				</div>

			</div>
		</div>
	</div>

	<!-- YAZAR POPUP -->
	<div id="yazar-popup-overlay" class="popup-overlay" onclick="yazarPopupKapat()">
		<div id="yazar-popup" class="popup-modal" onclick="event.stopPropagation()">

			@if (User.IsInRole("admin"))
			{
				<button class="popup-duzenle" onclick="yazarDuzenle()" title="Bu yazarı düzenle">✎</button>
			}
			<button class="popup-kapat" onclick="yazarPopupKapat()">✕</button>

			<div class="popup-icerik">

				<!-- Sol: yazar fotoğrafı (kitap kapağıyla aynı boyutlandırma mantığı) -->
				<div class="popup-sol">
					<div class="popup-kapak yazar-kapak">
						<img id="yazar-popup-foto" src="" alt="" />
					</div>
				</div>

				<!-- Sağ: üstte sabit isim + yaşam aralığı, altta kaydırılabilir biyografi + kitaplar -->
				<div class="popup-sag">

					<div class="popup-sag-sabit">
						<h2 id="yazar-popup-ad" class="popup-baslik"></h2>
						<p id="yazar-popup-yasam" class="popup-yayinevi-adi"></p>
					</div>

					<div class="popup-sag-kaydirilabilir" id="yazar-popup-scroll-alani">

						<div class="popup-aciklama">
							<p id="yazar-popup-aciklama"></p>
						</div>

						<!-- Yazarın kitapları: kitap popup'ındaki seri bölümüyle aynı satır/kart deseni -->
						<div class="popup-seri" id="yazar-popup-kitaplar"></div>

					</div>

				</div>

			</div>
		</div>
	</div>

	<!-- Seri / ilgili kitap mantığı ve yazar->kitap ters ilişkisi için tüm kitapların özet verisi -->
	<script id="tum-kitaplar-data" type="application/json">@Html.Raw(kitapVerileriJson)</script>
	<script id="tum-yazarlar-data" type="application/json">@Html.Raw(yazarVerileriJson)</script>

	<script src="~/js/bookland/bookland.js"></script>
</body>
</html>
