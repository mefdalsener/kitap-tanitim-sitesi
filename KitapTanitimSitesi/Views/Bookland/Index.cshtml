@model KitapTanitimSitesi.Models.BooklandViewModel

@{
	ViewData["Title"] = "Bookland";

	// Kitapları Türkçe alfabetik sıraya göre diz ve popup / seri mantığı için
	// gerekli tüm bilgiyi tek seferde JSON'a hazır hale getir.
	var trCulture = System.Globalization.CultureInfo.GetCultureInfo("tr-TR");
	var siraliKitaplar = Model.Books
		.OrderBy(b => b.BookName, StringComparer.Create(trCulture, ignoreCase: true))
		.ToList();

	var kitapVerileri = siraliKitaplar.Select(kitap => new
	{
		id = kitap.BookID,
		ad = kitap.BookName,
		kapak = kitap.BookCoverImage_URL ?? "",
		yazar = string.Join(", ", kitap.BookAuthors.Select(ba => ba.Author.AuthorName + " " + ba.Author.AuthorSurname)),
		yazarIds = kitap.BookAuthors.Select(ba => ba.AuthorID).ToList(),
		yayinevi = string.Join(", ", kitap.BookPublishers.Select(bp => bp.Publisher.PublisherName)),
		yayineviIds = kitap.BookPublishers.Select(bp => bp.PublisherID).ToList(),
		ilkYil = kitap.FirstPublishYear.HasValue ? kitap.FirstPublishYear.Value.ToString() : "",
		basimYili = string.Join(", ", kitap.BookPublishers.Select(bp => bp.PublishYear.HasValue ? bp.PublishYear.Value.ToString() : "")),
		sayfa = string.Join(", ", kitap.BookPublishers.Select(bp => bp.PageCount.HasValue ? bp.PageCount.Value.ToString() : "")),
		sayfaSayilari = kitap.BookPublishers.Where(bp => bp.PageCount.HasValue).Select(bp => bp.PageCount.Value).ToList(),
		tur = string.Join(", ", kitap.BookGenres.Select(bg => bg.Genre.GenreName)),
		turIds = kitap.BookGenres.Select(bg => bg.GenreID).ToList(),
		cevirmen = string.Join(", ", kitap.BookTranslators.Select(bt => bt.Translator.TranslatorName + " " + bt.Translator.TranslatorSurname)),
		cevirmenIds = kitap.BookTranslators.Select(bt => bt.TranslatorID).ToList(),
		aciklama = kitap.BookDescription ?? "",
		seriesId = kitap.SeriesID,
		seriesOrder = kitap.SeriesOrder
	}).ToList();

	// Filtre panelinde SADECE gerçekten en az bir kitapta kullanılan
	// yazar / yayınevi / çevirmen / tür / seri seçeneklerinin görünmesi için
	// kullanılan ID'lerin kümesini çıkarıyoruz. Böylece SQL tablosunda kayıtlı
	// ama hiçbir kitapta olmayan bir tür (örn. "Anı") filtre listesinde görünmez.
	var kullanilanYazarIdleri = kitapVerileri.SelectMany(k => k.yazarIds).Distinct().ToHashSet();
	var kullanilanYayineviIdleri = kitapVerileri.SelectMany(k => k.yayineviIds).Distinct().ToHashSet();
	var kullanilanCevirmenIdleri = kitapVerileri.SelectMany(k => k.cevirmenIds).Distinct().ToHashSet();
	var kullanilanTurIdleri = kitapVerileri.SelectMany(k => k.turIds).Distinct().ToHashSet();
	var kullanilanSeriIdleri = kitapVerileri
		.Where(k => k.seriesId != null)
		.Select(k => (int)k.seriesId)
		.Distinct()
		.ToHashSet();

	var tumSayfaSayilari = siraliKitaplar
	.SelectMany(k => k.BookPublishers)
	.Where(bp => bp.PageCount.HasValue)
	.Select(bp => bp.PageCount.Value)
	.ToList();

	var sayfaMinDeger = tumSayfaSayilari.Any() ? (tumSayfaSayilari.Min() / 10) * 10 : 0;
	var sayfaMaxDeger = tumSayfaSayilari.Any() ? ((tumSayfaSayilari.Max() / 10) + 1) * 10 : 2000;

	var kitapVerileriJson = System.Text.Json.JsonSerializer.Serialize(kitapVerileri);
	var kitapVerileriMap = kitapVerileri.ToDictionary(k => k.id);

	// Yazarları Türkçe alfabetik sıraya göre diz (Ad Soyad) ve popup'ta
	// gösterilecek/istemci tarafında kullanılacak tüm bilgiyi tek seferde JSON'a hazırla.
	// Not: Yazar -> Kitap ilişkisi ayrı bir sorgu ile değil, kitap verisinde zaten
	// var olan yazarIds alanı üzerinden (ters yönde) istemci tarafında kuruluyor —
	// tıpkı seri/ilgili kitaplar mantığında olduğu gibi, ekstra sorgu gerekmiyor.
	var siraliYazarlar = Model.Authors
		.OrderBy(a => a.AuthorName + " " + a.AuthorSurname, StringComparer.Create(trCulture, ignoreCase: true))
		.ToList();

	var yazarVerileri = siraliYazarlar.Select(yazar => new
	{
		id = yazar.AuthorID,
		ad = yazar.AuthorName + " " + yazar.AuthorSurname,
		foto = yazar.AuthorImage_URL ?? "",
		dogumYili = yazar.AuthorBirthYear,
		olumYili = yazar.AuthorDeathYear,
		aciklama = yazar.AuthorBiography ?? ""
	}).ToList();

	var yazarVerileriJson = System.Text.Json.JsonSerializer.Serialize(yazarVerileri);

}

<!DOCTYPE html>
<html lang="tr">
<head>
	<meta charset="utf-8" />
	<title>@ViewData["Title"]</title>
	<link rel="stylesheet" href="~/css/site.css" />

	<link rel="preconnect" href="https://fonts.googleapis.com">
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
	<link href="https://fonts.googleapis.com/css2?family=Rakkas&family=Sacramento&family=Special+Elite&display=swap" rel="stylesheet">

	<style>
			/* === GENEL === */
			* {
				margin: 0;
				padding: 0;
				box-sizing: border-box;
			}

			body {
				margin: 0;
				padding: 0;
				background-color: #F4F8FB;
				color: #26313D;
			}

			/* === ÜST BAR === */
			.top-bar {
				position: sticky;
				top: 0;
				height: 64px;
				width: 100%;
				margin: 0;
				padding: 0 28px;
				background-color: #599ED2;
				box-sizing: border-box;
				z-index: 100;
				display: flex;
				align-items: center;
				justify-content: space-between;
				box-shadow: 0 2px 12px rgba(38,49,61,0.10);
			}

			.top-bar-left {
				display: flex;
				align-items: center;
				gap: 36px;
			}

			.search-area {
				flex: 1;
				max-width: 380px;
				margin: 0 24px;
			}

			.search-input {
				width: 100%;
				padding: 9px 16px;
				border: none;
				border-radius: 999px;
				background: rgba(255,255,255,0.16);
				color: #FFFFFF;
				font-size: 14px;
				outline: none;
				transition: background 0.2s ease;
			}

				.search-input::placeholder {
					color: rgba(255,255,255,0.75);
				}

				.search-input:focus {
					background: rgba(255,255,255,0.28);
				}

			.site-name img {
				border-radius: 10px;
			}

			/* --- Navigasyon butonları (Kitaplar / Yazarlar) --- */
			.nav-buttons {
				display: flex;
				align-items: center;
				gap: 6px;
				background: rgba(255,255,255,0.12);
				padding: 4px;
				border-radius: 999px;
			}

			.nav-btn {
				border: none;
				background: transparent;
				color: rgba(255,255,255,0.85);
				font-size: 14px;
				font-weight: 600;
				padding: 8px 18px;
				border-radius: 999px;
				cursor: pointer;
				transition: background 0.25s ease, color 0.25s ease;
			}

				.nav-btn:hover {
					color: #FFFFFF;
					background: rgba(255,255,255,0.14);
				}

				.nav-btn.active {
					background: #FFFFFF;
					color: #599ED2;
				}

			/* --- Giriş / Kayıt butonları --- */
			.auth-buttons {
				display: flex;
				align-items: center;
				gap: 10px;
			}

			.auth-btn {
				border: none;
				font-size: 14px;
				font-weight: 600;
				padding: 9px 20px;
				border-radius: 10px;
				cursor: pointer;
				transition: transform 0.15s ease, background 0.2s ease, box-shadow 0.2s ease;
			}

				.auth-btn:active {
					transform: scale(0.97);
				}

			.auth-btn-ghost {
				background: transparent;
				color: #FFFFFF;
				border: 1.5px solid rgba(255,255,255,0.55);
			}

				.auth-btn-ghost:hover {
					background: rgba(255,255,255,0.12);
					border-color: #FFFFFF;
				}

			.auth-btn-solid {
				background: #26313D;
				color: #FFFFFF;
			}

				.auth-btn-solid:hover {
					background: #1B242D;
					box-shadow: 0 4px 12px rgba(38,49,61,0.35);
				}

			/* === SAYFA DÜZENİ === */
			.content-wrapper {
				display: flex;
				align-items: stretch;
				min-height: calc(100vh - 60px);
			}

			.view-section {
				display: flex;
				width: 100%;
				align-items: flex-start;
			}

				.view-section:not(.active) {
					display: none;
				}

			/* === FİLTRE ALANI === */
			.filter-area {
				flex-basis: 22%;
				flex-shrink: 0;
				position: sticky;
				top: 60px;
				align-self: flex-start;
				height: calc(100vh - 60px);
				padding: 12px 8px;
				display: flex;
				flex-direction: column;
				overflow: hidden;
			}

			.filter-reset-bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 10px 14px;
				margin-bottom: 10px;
				background-color: #FFFFFF;
				border: 1px solid #DCE8F2;
				border-radius: 14px;
				box-shadow: 0 4px 18px rgba(89,158,210,0.08);
				flex-shrink: 0;
			}

			.filter-reset-baslik {
				font-weight: bold;
				font-size: 14px;
				color: #26313D;
			}

			.filter-reset-btn {
				border: 1px solid #599ED2;
				background: transparent;
				color: #599ED2;
				font-size: 12px;
				font-weight: 600;
				padding: 6px 12px;
				border-radius: 999px;
				cursor: pointer;
				transition: background 0.2s ease, color 0.2s ease;
			}

				.filter-reset-btn:hover {
					background: #599ED2;
					color: #FFFFFF;
				}

			.filter-box {
				display: flex;
				flex-direction: column;
				border: 1px solid #DCE8F2;
				border-radius: 14px;
				overflow: hidden;
				flex: 1;
				min-height: 0;
				background-color: #FFFFFF;
				box-shadow: 0 4px 18px rgba(89,158,210,0.08);
			}

			.filter-item {
				border-bottom: 1px solid #EAF2F8;
				flex: 1 1 0;
				transition: flex-grow 0.4s ease;
				overflow: hidden;
				display: flex;
				flex-direction: column;
				min-height: 0;
			}

				.filter-item span {
					font-family: Helvetica, Arial, sans-serif;
					font-size: 20px;
				}

				.filter-item:last-child {
					border-bottom: none;
				}

				.filter-item.open {
					flex: 5 1 0;
				}

			.filter-header {
				display: flex;
				justify-content: space-between;
				align-items: center;
				padding: 14px 16px;
				cursor: pointer;
				font-weight: bold;
				font-size: 14px;
				background: #FFFFFF;
				color: #26313D;
				user-select: none;
				flex: 0 0 auto;
			}

			.filter-item.open .filter-header {
				flex: 0;
				background: #599ED2;
				color: #FFFFFF;
			}

			.filter-header:hover {
				background: #EAF3FB;
				color: #26313D;
			}

			.filter-item.open .filter-header:hover {
				background: #599ED2;
				color: #FFFFFF;
			}

			.filter-arrow {
				font-size: 11px;
				transition: transform 0.3s ease;
				color: #599ED2;
			}

			.filter-item.open .filter-arrow {
				transform: rotate(180deg);
				color: #FFFFFF;
			}

			.filter-content {
				flex: 0 0 auto;
				max-height: 0;
				opacity: 0;
				overflow: hidden;
				padding: 0 12px;
				background: #FFFFFF;
				display: flex;
				flex-direction: column;
				transform: translateY(-6px);
				transition: max-height 0.4s ease, opacity 0.3s ease 0.05s, padding 0.4s ease, transform 0.35s ease;
			}

			.filter-item.open .filter-content {
				flex: 1 1 auto;
				max-height: 1000px;
				opacity: 1;
				padding: 10px 12px;
				transform: translateY(0);
			}

			.filter-search {
				width: 100%;
				padding: 7px 10px;
				border: 1px solid #DCE8F2;
				border-radius: 8px;
				font-size: 13px;
				margin-bottom: 8px;
				box-sizing: border-box;
				flex-shrink: 0;
				background: #F4F8FB;
				color: #26313D;
			}

				.filter-search::placeholder {
					color: #8CA3B8;
				}

			.filter-list {
				display: flex;
				flex-direction: column;
				gap: 6px;
				overflow-y: auto;
				flex: 1;
				min-height: 0;
			}

			.filter-option {
				display: flex;
				align-items: center;
				gap: 8px;
				font-size: 13px;
				cursor: pointer;
				padding: 3px 2px;
				flex-shrink: 0;
				color: #26313D;
			}

				.filter-option:hover {
					color: #599ED2;
				}

				/* Arama kutusuyla eşleşmeyen ya da mevcut filtre kombinasyonunda
																											   hiçbir kitap döndürmeyecek seçenekler tamamen gizlenir. */
				.filter-option.arama-gizli,
				.filter-option.gecersiz {
					display: none !important;
				}

			/* === SAYFA SAYISI SLIDER === */
			.range-container {
				position: relative;
				height: 30px;
				margin: 8px 0;
			}

				.range-container input[type="range"] {
					position: absolute;
					width: 100%;
					height: 4px;
					background: transparent;
					pointer-events: none;
					appearance: none;
					top: 50%;
					transform: translateY(-50%);
				}

					.range-container input[type="range"]::-webkit-slider-thumb {
						appearance: none;
						width: 16px;
						height: 16px;
						border-radius: 50%;
						background: #599ED2;
						cursor: pointer;
						pointer-events: all;
						border: 2px solid #FFFFFF;
						box-shadow: 0 1px 4px rgba(0,0,0,0.2);
					}

			.range-labels {
				display: flex;
				justify-content: space-between;
				font-size: 13px;
				color: #599ED2;
				margin-bottom: 4px;
			}

			/* === KİTAP ALANI === */
			.book-grid {
				flex-grow: 1;
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(200px, 230px));
				grid-gap: 20px;
				padding: 12px;
				align-content: start;
			}

			.book-card {
				max-width: 230px;
				padding: 15px;
				display: flex;
				flex-direction: column;
				gap: 8px;
				border-radius: 14px;
				background-color: #FFFFFF;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}

				.book-card:hover {
					transform: translateY(-4px);
					box-shadow: 0 10px 24px rgba(89,158,210,0.18);
				}

			.book-cover {
				width: 100%;
				aspect-ratio: 2 / 3;
				overflow: hidden;
				border-radius: 10px;
				box-shadow: 4px 6px 14px rgba(38,49,61,0.12);
			}

			/* === ARAMA SONUCU BULUNAMADI (EJDERHA) DURUMU === */
			.arama-bos-durum {
				flex-grow: 1;
				display: none;
				flex-direction: column;
				align-items: center;
				justify-content: center;
				gap: 18px;
				padding: 60px 20px;
				text-align: center;
			}

				.arama-bos-durum img {
					width: 100%;
					max-width: 600px;
					height: auto;
				}

			.arama-bos-yazi {
				font-family: "Rakkas", serif;
				font-weight: 400;
				font-style: normal;
				font-size: 40px;
				color: #5B6B7A;
				max-width: 500px;
				line-height: 1.5;
			}

			.book-cover img {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: cover;
				object-position: center;
			}

			.book-information p {
				margin: 0;
			}

			.book-title {
				font-family: Helvetica, Arial, sans-serif;
				font-size: 18px;
				font-weight: bold;
				color: #26313D;
			}

			.book-author {
				font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
				font-size: 14px;
				font-weight: 300;
				font-style: italic;
				color: #599ED2;
			}

			.book-publisher {
				font-size: 13px;
				color: #8CA3B8;
			}

			/* === YAZAR ALANI === */
			.author-grid {
				flex-grow: 1;
				width: 100%;
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				grid-gap: 24px;
				padding: 24px;
				align-content: start;
			}

			.author-card {
				padding: 12px;
				display: flex;
				flex-direction: row; 
				align-items: center;
				gap: 12px;
				height: 100px;
				max-height: 100px;
				overflow: hidden;
				border-radius: 14px;
				background-color: #FFFFFF;
				transition: transform 0.2s ease, box-shadow 0.2s ease;
			}

				.author-card:hover {
					transform: translateY(-4px);
					box-shadow: 0 10px 24px rgba(89,158,210,0.18);
				}

			.author-cover {
				width: 76px;
				height: 76px;
				flex-shrink: 0;
				overflow: hidden;
				border-radius: 10px;
				background: #F4F8FB;
				box-shadow: 4px 6px 14px rgba(38,49,61,0.12);
			}

				.author-cover img {
					width: 100%;
					height: 100%;
					display: block;
					object-fit: cover;
					object-position: center top;
				}

			.author-information {
				display: flex;
				flex-direction: column;
				gap: 3px;
				min-width: 0; /* sağdaki metin taşınca kartı genişletmesin */
				overflow: hidden;
			}

			.author-name {
				font-family: Helvetica, Arial, sans-serif;
				font-size: 15px; /* 18px yerine */
				font-weight: bold;
				color: #26313D;
			}

			.author-lifespan {
				font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
				font-size: 11px; /* 13px yerine */
				font-weight: 300;
				font-style: italic;
				color: #599ED2;
			}

			.author-bio-preview {
				font-size: 12px;
				color: #26313D;
				line-height: 1.35;
				display: -webkit-box;
				-webkit-line-clamp: 2; /* 3 yerine 2 */
				-webkit-box-orient: vertical;
				overflow: hidden;
				text-overflow: ellipsis;
			}

			/* === POPUP (ORTAK) ===
							 Hem kitap popup'ı hem de yazar popup'ı bu paylaşılan sınıfları kullanır.
							 Element ID'leri sadece JS tarafında hangi popup'ın açılıp kapandığını
							 ayırt etmek için tutuluyor; görsel stiller tamamen ortak. */
			.popup-overlay {
				display: none;
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				background: rgba(38,49,61,0.45);
				z-index: 200;
				align-items: center;
				justify-content: center;
			}

				.popup-overlay.aktif {
					display: flex;
				}

			.popup-modal {
				background: #FFFFFF;
				border-radius: 16px;
				width: 1000px;
				max-width: 90vw;
				height: 90vh;
				max-height: 90vh;
				overflow: hidden;
				position: relative;
				display: flex;
				flex-direction: column;
				box-shadow: 0 12px 48px rgba(38,49,61,0.22);
			}

			.popup-kapat {
				position: absolute;
				top: 12px;
				right: 16px;
				background: none;
				border: none;
				font-size: 24px;
				cursor: pointer;
				color: #8CA3B8;
				z-index: 10;
			}

				.popup-kapat:hover {
					color: #26313D;
				}
			/* Çarpının solundaki "Düzenle" butonu: aktif kitabı admin paneline
																											güncelleme modunda gönderir. */
			.popup-duzenle {
				position: absolute;
				top: 10px;
				right: 52px;
				background: none;
				border: none;
				font-size: 18px;
				cursor: pointer;
				color: #8CA3B8;
				z-index: 10;
				padding: 6px;
				border-radius: 6px;
				transition: background 0.2s ease, color 0.2s ease;
			}

				.popup-duzenle:hover {
					color: #599ED2;
					background: rgba(89,158,210,0.12);
				}
			/* İçerik: sol = kapak (dinamik genişlik / sabit yükseklik), sağ = sabit başlık + kaydırılabilir gövde */
			.popup-icerik {
				display: flex;
				align-items: stretch;
				gap: 32px;
				padding: 36px 36px 36px 36px;
				overflow: hidden;
				flex: 1;
				min-height: 0;
			}

			.popup-sol {
				flex-shrink: 0;
				display: flex;
				min-height: 0;
			}

			.popup-kapak {
				height: 100%;
				max-height: 100%;
				width: auto;
				border-radius: 10px;
				overflow: hidden;
				background: #F4F8FB;
				box-shadow: 8px 15px 24px rgba(38,49,61,0.16);
			}

				.popup-kapak img {
					height: 100%;
					width: auto;
					display: block;
					object-fit: contain;
				}

			.yazar-kapak {
				width: 220px;
				height: 220px;
				max-width: 220px;
				max-height: 220px;
			}

				.yazar-kapak img {
					width: 100%;
					height: 100%;
					object-fit: contain;
				}

			.popup-sag {
				flex: 1 1 auto;
				min-width: 0;
				min-height: 0;
				display: flex;
				flex-direction: column;
				overflow: hidden;
			}

			/* Sabit kalan üst kısım: kitap adı + yazar + yayınevi */
			.popup-sag-sabit {
				flex-shrink: 0;
				padding-right: 20px;
				padding-bottom: 18px;
				border-bottom: 1px solid #EAF2F8;
			}

			.popup-baslik {
				font-size: 28px;
				font-family: Helvetica, Arial, sans-serif;
				font-weight: bold;
				color: #26313D;
				margin: 0 0 10px 0;
			}

			.popup-yazar-yayinevi {
				display: flex;
				flex-direction: column;
				gap: 3px;
			}

			.popup-yazar-adi {
				font-size: 16px;
				font-style: italic;
				font-weight: bold;
				color: #599ED2;
				margin: 0;
			}

			.popup-yayinevi-adi {
				font-size: 14px;
				color: #8CA3B8;
				margin: 0;
			}

			/* Kaydırılabilir alt kısım: bilgi tablosu + açıklama + seri bölümü */
			.popup-sag-kaydirilabilir {
				flex: 1;
				min-height: 0;
				overflow-y: auto;
				padding-right: 20px;
				padding-top: 18px;
				display: flex;
				flex-direction: column;
				gap: 18px;
			}

			.popup-bilgiler {
				display: flex;
				flex-direction: column;
				gap: 6px;
				background: #F4F8FB;
				border-radius: 10px;
				padding: 14px;
				border: 1px solid #DCE8F2;
			}

			.popup-bilgi-satir {
				display: flex;
				gap: 12px;
				font-size: 15px;
				color: #26313D;
			}

			.popup-etiket {
				color: #599ED2;
				min-width: 130px;
				flex-shrink: 0;
				font-weight: bold;
			}

			.popup-aciklama {
				border: 1px solid #DCE8F2;
				border-radius: 10px;
				padding: 18px;
				font-size: 16px;
				line-height: 1.6;
				color: #26313D;
				background: #FBFDFE;
			}

			/* === SERİ BÖLÜMÜ === */
			.popup-seri {
				display: none;
				flex-direction: column;
				gap: 14px;
			}

			.seri-baslik {
				font-weight: bold;
				font-size: 13px;
				color: #599ED2;
				text-transform: uppercase;
				letter-spacing: 0.6px;
				margin-top: 4px;
			}

			.seri-kitap-satir {
				display: flex;
				align-items: center;
				gap: 14px;
				padding: 10px;
				border: 1px solid #DCE8F2;
				border-radius: 12px;
				cursor: pointer;
				transition: background 0.2s ease, border-color 0.2s ease;
				background: #FFFFFF;
			}

				.seri-kitap-satir:hover {
					background: #EAF3FB;
					border-color: #BBDAF0;
				}

			.seri-kitap-kapak {
				width: 48px;
				height: 72px;
				flex-shrink: 0;
				border-radius: 6px;
				overflow: hidden;
				background: #F4F8FB;
				box-shadow: 2px 3px 8px rgba(38,49,61,0.12);
			}

				.seri-kitap-kapak img {
					width: 100%;
					height: 100%;
					object-fit: cover;
				}

			.seri-kitap-bilgi {
				display: flex;
				flex-direction: column;
				gap: 3px;
				min-width: 0;
			}

			.seri-etiket {
				font-size: 11px;
				color: #8CA3B8;
				font-weight: bold;
				text-transform: uppercase;
				letter-spacing: 0.4px;
			}

			.seri-kitap-adi {
				font-size: 14px;
				font-weight: bold;
				color: #26313D;
				overflow: hidden;
				text-overflow: ellipsis;
				white-space: nowrap;
			}

			.ilgili-liste {
				display: flex;
				flex-direction: row;
				flex-wrap: wrap;
				gap: 14px;
			}

				.ilgili-liste .seri-kitap-satir {
					flex-direction: column;
					align-items: flex-start;
					width: 100px;
					padding: 8px;
					gap: 8px;
				}

				.ilgili-liste .seri-kitap-kapak {
					width: 100%;
					height: 130px;
				}

				.ilgili-liste .seri-kitap-adi {
					white-space: normal;
					display: -webkit-box;
					-webkit-line-clamp: 2;
					-webkit-box-orient: vertical;
					overflow: hidden;
				}
	</style>
</head>
<body>

	<!-- ÜST BAR -->
	<header class="top-bar">
		<div class="top-bar-left">
			<div class="site-name">
				<img src="~/images/med-logo-1.png" alt="Logo" style="height: 40px; object-fit: contain;" />
			</div>

			<nav class="nav-buttons">
				<button id="btn-kitaplar" class="nav-btn active">Kitaplar</button>
				<button id="btn-yazarlar" class="nav-btn">Yazarlar</button>
			</nav>
		</div>

		<div class="search-area">
			<input type="text" id="kitap-arama-input" class="search-input"
				   placeholder="🔍 Kitap ara..." oninput="kitapAramaFiltrele()" />
		</div>

		<div class="auth-buttons">
			<button class="auth-btn auth-btn-ghost">Giriş Yap</button>
			<button class="auth-btn auth-btn-solid">Kayıt Ol</button>
		</div>
	</header>

	<!-- ANA İÇERİK -->
	<div class="content-wrapper">

		<!-- KİTAPLAR GÖRÜNÜMÜ -->
		<div id="view-kitaplar" class="view-section active">

			<aside class="filter-area">
				<div class="filter-reset-bar">
					<span class="filter-reset-baslik">Filtreler</span>
					<button class="filter-reset-btn" onclick="filtreleriSifirla()">Filtreleri Temizle</button>
				</div>
				<div class="filter-box">

					<!-- YAZAR FİLTRESİ -->
					<div class="filter-item" id="filter-yazar">
						<div class="filter-header" onclick="toggleFilter('yazar')">
							<span>Yazar</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-yazar">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('yazar', this.value)" />
							<div class="filter-list" id="list-yazar">
								@foreach (var author in Model.Authors.Where(a => kullanilanYazarIdleri.Contains(a.AuthorID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@author.AuthorID" onchange="filtreUygula()" />
										@author.AuthorName @author.AuthorSurname
									</label>
								}
							</div>
						</div>
					</div>

					<!-- YAYINEVİ FİLTRESİ -->
					<div class="filter-item" id="filter-yayinevi">
						<div class="filter-header" onclick="toggleFilter('yayinevi')">
							<span>Yayınevi</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-yayinevi">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('yayinevi', this.value)" />
							<div class="filter-list" id="list-yayinevi">
								@foreach (var publisher in Model.Publishers.Where(p => kullanilanYayineviIdleri.Contains(p.PublisherID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@publisher.PublisherID" onchange="filtreUygula()" />
										@publisher.PublisherName
									</label>
								}
							</div>
						</div>
					</div>

					<!-- ÇEVİRMEN FİLTRESİ -->
					<div class="filter-item" id="filter-cevirmen">
						<div class="filter-header" onclick="toggleFilter('cevirmen')">
							<span>Çevirmen</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-cevirmen">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('cevirmen', this.value)" />
							<div class="filter-list" id="list-cevirmen">
								@foreach (var translator in Model.Translators.Where(t => kullanilanCevirmenIdleri.Contains(t.TranslatorID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@translator.TranslatorID" onchange="filtreUygula()" />
										@translator.TranslatorName @translator.TranslatorSurname
									</label>
								}
							</div>
						</div>
					</div>

					<!-- SERİ FİLTRESİ -->
					<div class="filter-item" id="filter-seri">
						<div class="filter-header" onclick="toggleFilter('seri')">
							<span>Seri</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-seri">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('seri', this.value)" />
							<div class="filter-list" id="list-seri">
								@foreach (var seri in Model.SeriesList.Where(s => kullanilanSeriIdleri.Contains(s.SeriesID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@seri.SeriesID" onchange="filtreUygula()" />
										@seri.SeriesName
									</label>
								}
							</div>
						</div>
					</div>

					<!-- TÜR FİLTRESİ -->
					<div class="filter-item" id="filter-tur">
						<div class="filter-header" onclick="toggleFilter('tur')">
							<span>Tür</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-tur">
							<input type="text" class="filter-search" placeholder="🔍 Ara..." oninput="aramaYap('tur', this.value)" />
							<div class="filter-list" id="list-tur">
								@foreach (var tur in Model.Genres.Where(g => kullanilanTurIdleri.Contains(g.GenreID)))
								{
									<label class="filter-option">
										<input type="checkbox" value="@tur.GenreID" onchange="filtreUygula()" />
										@tur.GenreName
									</label>
								}
							</div>
						</div>
					</div>

					<!-- SAYFA SAYISI FİLTRESİ -->
					<div class="filter-item" id="filter-sayfa">
						<div class="filter-header" onclick="toggleFilter('sayfa')">
							<span>Sayfa Sayısı</span>
							<span class="filter-arrow">▼</span>
						</div>
						<div class="filter-content" id="content-sayfa">
							<div class="range-labels">
								<span id="range-min-label">@sayfaMinDeger</span>
								<span id="range-max-label">@sayfaMaxDeger</span>
							</div>
							<div class="range-container">
								<input type="range" id="range-min" min="@sayfaMinDeger" max="@sayfaMaxDeger" value="@sayfaMinDeger" step="10" oninput="rangeGuncelle()" />
								<input type="range" id="range-max" min="@sayfaMinDeger" max="@sayfaMaxDeger" value="@sayfaMaxDeger" step="10" oninput="rangeGuncelle()" />
							</div>
						</div>
					</div>

				</div>
			</aside>

			<main class="book-grid" id="book-grid">
				@foreach (var kitap in siraliKitaplar)
				{
					var veri = kitapVerileriMap[kitap.BookID];
					<div class="book-card" onclick="popupAc(kitapMap[@kitap.BookID])" style="cursor:pointer;">
						<div class="book-cover">
							@if (!string.IsNullOrEmpty(kitap.BookCoverImage_URL))
							{
								<img src="@kitap.BookCoverImage_URL" alt="@kitap.BookName" />
							}
						</div>
						<div class="book-information">
							<p class="book-title">@kitap.BookName</p>
							<p class="book-author">@veri.yazar</p>
							<p class="book-publisher">@veri.yayinevi</p>
						</div>
					</div>
				}
			</main>

			<div class="arama-bos-durum" id="arama-bos-durum">
				<img src="~/images/little-dragon-in-library.png" alt="Kitap bulunamadı" />
				<p class="arama-bos-yazi" id="arama-bos-yazi"></p>
			</div>

		</div>

		<!-- YAZARLAR GÖRÜNÜMÜ -->
		<div id="view-yazarlar" class="view-section">
			<main class="author-grid" id="author-grid">
				@foreach (var yazar in siraliYazarlar)
				{
					<div class="author-card" onclick="yazarPopupAc(yazarMap[@yazar.AuthorID])" style="cursor:pointer;">
						<div class="author-cover">
							@if (!string.IsNullOrEmpty(yazar.AuthorImage_URL))
							{
								<img src="@yazar.AuthorImage_URL" alt="@yazar.AuthorName @yazar.AuthorSurname" />
							}
						</div>
						<div class="author-information">
							<p class="author-name">@yazar.AuthorName @yazar.AuthorSurname</p>
							<p class="author-lifespan">
								@if (yazar.AuthorBirthYear.HasValue)
								{
									@(yazar.AuthorBirthYear + " – " + (yazar.AuthorDeathYear.HasValue ? yazar.AuthorDeathYear.Value.ToString() : "Hayatta"))
								}
							</p>
							<p class="author-bio-preview">@yazar.AuthorBiography</p>
						</div>
					</div>
				}
			</main>
		</div>

	</div>

	<!-- KİTAP POPUP -->
	<div id="kitap-popup-overlay" class="popup-overlay" onclick="popupKapat()">
		<div id="kitap-popup" class="popup-modal" onclick="event.stopPropagation()">

			<button class="popup-duzenle" onclick="kitapDuzenle()" title="Bu kitabı düzenle">✎</button>
			<button class="popup-kapat" onclick="popupKapat()">✕</button>

			<div class="popup-icerik">

				<!-- Sol: sadece kapak (yükseklik sabit, genişlik kapağın kendi oranına göre dinamik) -->
				<div class="popup-sol">
					<div class="popup-kapak">
						<img id="popup-kapak-img" src="" alt="" />
					</div>
				</div>

				<!-- Sağ: üstte sabit başlık alanı, altta kaydırılabilir gövde -->
				<div class="popup-sag">

					<div class="popup-sag-sabit">
						<h2 id="popup-kitap-adi" class="popup-baslik"></h2>
						<div class="popup-yazar-yayinevi">
							<p id="popup-yazar" class="popup-yazar-adi"></p>
							<p id="popup-yayinevi" class="popup-yayinevi-adi"></p>
						</div>
					</div>

					<div class="popup-sag-kaydirilabilir" id="popup-scroll-alani">

						<div class="popup-bilgiler">
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">İlk Yayın Yılı</span>
								<span id="popup-ilk-yil"></span>
							</div>
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">Basım Yılı</span>
								<span id="popup-basim-yili"></span>
							</div>
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">Sayfa Sayısı</span>
								<span id="popup-sayfa"></span>
							</div>
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">Tür</span>
								<span id="popup-tur"></span>
							</div>
							<div class="popup-bilgi-satir">
								<span class="popup-etiket">Çevirmen</span>
								<span id="popup-cevirmen"></span>
							</div>
						</div>

						<div class="popup-aciklama">
							<p id="popup-aciklama-metin"></p>
						</div>

						<!-- Seri / ilgili kitaplar bölümü: sadece kitap bir seriye bağlıysa görünür -->
						<div class="popup-seri" id="popup-seri"></div>

					</div>

				</div>

			</div>
		</div>
	</div>

	<!-- YAZAR POPUP -->
	<div id="yazar-popup-overlay" class="popup-overlay" onclick="yazarPopupKapat()">
		<div id="yazar-popup" class="popup-modal" onclick="event.stopPropagation()">

			<button class="popup-duzenle" onclick="yazarDuzenle()" title="Bu yazarı düzenle">✎</button>
			<button class="popup-kapat" onclick="yazarPopupKapat()">✕</button>

			<div class="popup-icerik">

				<!-- Sol: yazar fotoğrafı (kitap kapağıyla aynı boyutlandırma mantığı) -->
				<div class="popup-sol">
					<div class="popup-kapak yazar-kapak">
						<img id="yazar-popup-foto" src="" alt="" />
					</div>
				</div>

				<!-- Sağ: üstte sabit isim + yaşam aralığı, altta kaydırılabilir biyografi + kitaplar -->
				<div class="popup-sag">

					<div class="popup-sag-sabit">
						<h2 id="yazar-popup-ad" class="popup-baslik"></h2>
						<p id="yazar-popup-yasam" class="popup-yayinevi-adi"></p>
					</div>

					<div class="popup-sag-kaydirilabilir" id="yazar-popup-scroll-alani">

						<div class="popup-aciklama">
							<p id="yazar-popup-aciklama"></p>
						</div>

						<!-- Yazarın kitapları: kitap popup'ındaki seri bölümüyle aynı satır/kart deseni -->
						<div class="popup-seri" id="yazar-popup-kitaplar"></div>

					</div>

				</div>

			</div>
		</div>
	</div>

	<!-- Seri / ilgili kitap mantığı ve yazar->kitap ters ilişkisi için tüm kitapların özet verisi -->
	<script id="tum-kitaplar-data" type="application/json">@Html.Raw(kitapVerileriJson)</script>
	<script id="tum-yazarlar-data" type="application/json">@Html.Raw(yazarVerileriJson)</script>

	<script>
		const btnKitaplar = document.getElementById("btn-kitaplar");
		const btnYazarlar = document.getElementById("btn-yazarlar");
		const viewKitaplar = document.getElementById("view-kitaplar");
		const viewYazarlar = document.getElementById("view-yazarlar");

		const tumKitaplar = JSON.parse(
		document.getElementById("tum-kitaplar-data").textContent,
		);
		const kitapMap = {};
		tumKitaplar.forEach((k) => (kitapMap[k.id] = k));

		const tumYazarlar = JSON.parse(
		document.getElementById("tum-yazarlar-data").textContent,
		);
		const yazarMap = {};
		tumYazarlar.forEach((y) => (yazarMap[y.id] = y));

		btnKitaplar.addEventListener("click", () => {
		viewKitaplar.classList.add("active");
		viewYazarlar.classList.remove("active");
		btnKitaplar.classList.add("active");
		btnYazarlar.classList.remove("active");
		});

		btnYazarlar.addEventListener("click", () => {
		viewYazarlar.classList.add("active");
		viewKitaplar.classList.remove("active");
		btnYazarlar.classList.add("active");
		btnKitaplar.classList.remove("active");
		});

		function toggleFilter(ad) {
		const items = document.querySelectorAll(".filter-item");
		items.forEach((item) => {
		if (item.id === "filter-" + ad) {
		item.classList.toggle("open");
		} else {
		item.classList.remove("open");
		}
		});
		}

		function aramaYap(filtre, aramaMetni) {
		const liste = document.getElementById("list-" + filtre);
		const secenekler = liste.querySelectorAll(".filter-option");
		secenekler.forEach((s) => {
		const metin = s.textContent.toLowerCase();
		const eslesiyor = metin.includes(aramaMetni.toLowerCase());
		s.classList.toggle("arama-gizli", !eslesiyor);
		});
		}

		function rangeGuncelle() {
		const min = parseInt(document.getElementById("range-min").value);
		const max = parseInt(document.getElementById("range-max").value);

		if (min > max) document.getElementById("range-min").value = max;
		if (max < min) document.getElementById("range-max").value = min;

		document.getElementById("range-min-label").textContent =
		document.getElementById("range-min").value;
		document.getElementById("range-max-label").textContent =
		document.getElementById("range-max").value;

		filtreUygula();
		}

		function seciliDegerleriAl(filtreAdi) {
		const liste = document.getElementById("list-" + filtreAdi);
		const secili = liste.querySelectorAll('input[type="checkbox"]:checked');
		return Array.from(secili).map((cb) => parseInt(cb.value));
		}

		function diziKesisiyorMu(kitapDizisi, seciliDizi) {
		// Filtre seçilmemişse (dizi boşsa) bu kritere göre eleme yapma
		if (seciliDizi.length === 0) return true;
		if (!kitapDizisi) return false;
		return kitapDizisi.some((id) => seciliDizi.includes(id));
		}

		function diziKapsiyorMu(kitapDizisi, seciliDizi) {
		// Filtre seçilmemişse (dizi boşsa) bu kritere göre eleme yapma
		if (seciliDizi.length === 0) return true;
		if (!kitapDizisi) return false;
		// Kitap, seçilen TÜM id'leri içermeli (AND mantığı)
		return seciliDizi.every((id) => kitapDizisi.includes(id));
		}

		function kitapKartOlustur(kitap) {
		const kart = document.createElement("div");
		kart.className = "book-card";
		kart.style.cursor = "pointer";
		kart.addEventListener("click", () => popupAc(kitap));

		const kapakHtml = kitap.kapak
		? `<img src="${kitap.kapak}" alt="${kitap.ad}" />`
		: "";

		kart.innerHTML = `
		<div class="book-cover">${kapakHtml}</div>
		<div class="book-information">
		<p class="book-title">${kitap.ad}</p>
		<p class="book-author">${kitap.yazar}</p>
		<p class="book-publisher">${kitap.yayinevi}</p>
		</div>`;

		return kart;
		}

		function kitaplariRenderEt(liste) {
		const grid = document.getElementById("book-grid");
		grid.innerHTML = "";
		liste.forEach((kitap) => grid.appendChild(kitapKartOlustur(kitap)));
		}

		function filtreUygula() {
		const yazarSecili = seciliDegerleriAl("yazar");
		const yayineviSecili = seciliDegerleriAl("yayinevi");
		const cevirmenSecili = seciliDegerleriAl("cevirmen");
		const turSecili = seciliDegerleriAl("tur");
		const seriSecili = seciliDegerleriAl("seri");

		const sayfaMin = parseInt(document.getElementById("range-min").value);
		const sayfaMax = parseInt(document.getElementById("range-max").value);

		let filtrelenmis = tumKitaplar.filter((kitap) => {
		if (!diziKesisiyorMu(kitap.yazarIds, yazarSecili)) return false;
		if (!diziKesisiyorMu(kitap.yayineviIds, yayineviSecili)) return false;
		if (!diziKesisiyorMu(kitap.cevirmenIds, cevirmenSecili)) return false;
		if (!diziKapsiyorMu(kitap.turIds, turSecili)) return false;

		if (seriSecili.length > 0) {
		if (!kitap.seriesId || !seriSecili.includes(kitap.seriesId)) return false;
		}

		if (kitap.sayfaSayilari && kitap.sayfaSayilari.length > 0) {
		const araligaGiren = kitap.sayfaSayilari.some(
		(s) => s >= sayfaMin && s <= sayfaMax,
		);
		if (!araligaGiren) return false;
		}

		return true;
		});

		if (seriSecili.length > 0) {
		filtrelenmis.sort((a, b) => {
		const seriKarsilastirma = (a.seriesId ?? 0) - (b.seriesId ?? 0);
		if (seriKarsilastirma !== 0) return seriKarsilastirma;
		return (a.seriesOrder ?? 0) - (b.seriesOrder ?? 0);
		});
		} else {
		filtrelenmis.sort((a, b) => a.ad.localeCompare(b.ad, "tr-TR"));
		}

		kitaplariRenderEt(filtrelenmis);
		filtreSecenekleriniGuncelle();
		// Filtreler kart listesini sıfırdan oluşturduğu için, arama kutusunda
		// hâlâ bir metin varsa arama filtresini de yeniden uygula
		kitapAramaFiltrele();
		}

		// --- KADEMELİ (FACETED) FİLTRELEME ---
		// Bir kategoride (örn. Tür) seçim yapıldığında, diğer kategorilerdeki
		// (Yazar, Yayınevi, Çevirmen, Seri) artık hiç kitap döndürmeyecek
		// seçenekler otomatik olarak gizlenir. Örnek: "Bilim Kurgu" seçilince
		// yazar listesinde sadece bilim kurgu kitabı olan yazarlar kalır.
		const facetKategorileri = [
		{ ad: "yazar", idAlan: "yazarIds" },
		{ ad: "yayinevi", idAlan: "yayineviIds" },
		{ ad: "cevirmen", idAlan: "cevirmenIds" },
		{ ad: "tur", idAlan: "turIds" },
		{ ad: "seri", idAlan: "seriesId" },
		];

		function kategoriHaricFiltrele(haricKategori) {
		const yazarSecili =
		haricKategori === "yazar" ? [] : seciliDegerleriAl("yazar");
		const yayineviSecili =
		haricKategori === "yayinevi" ? [] : seciliDegerleriAl("yayinevi");
		const cevirmenSecili =
		haricKategori === "cevirmen" ? [] : seciliDegerleriAl("cevirmen");
		const turSecili = haricKategori === "tur" ? [] : seciliDegerleriAl("tur");
		const seriSecili = haricKategori === "seri" ? [] : seciliDegerleriAl("seri");

		const sayfaMin = parseInt(document.getElementById("range-min").value);
		const sayfaMax = parseInt(document.getElementById("range-max").value);

		return tumKitaplar.filter((kitap) => {
		if (!diziKesisiyorMu(kitap.yazarIds, yazarSecili)) return false;
		if (!diziKesisiyorMu(kitap.yayineviIds, yayineviSecili)) return false;
		if (!diziKesisiyorMu(kitap.cevirmenIds, cevirmenSecili)) return false;
		if (!diziKapsiyorMu(kitap.turIds, turSecili)) return false;

		if (seriSecili.length > 0) {
		if (!kitap.seriesId || !seriSecili.includes(kitap.seriesId)) return false;
		}

		if (
		haricKategori !== "sayfa" &&
		kitap.sayfaSayilari &&
		kitap.sayfaSayilari.length > 0
		) {
		const araligaGiren = kitap.sayfaSayilari.some(
		(s) => s >= sayfaMin && s <= sayfaMax,
		);
		if (!araligaGiren) return false;
		}

		return true;
		});
		}

		function gecerliIdSetiOlustur(kitaplar, idAlani) {
		const set = new Set();
		kitaplar.forEach((kitap) => {
		const deger = kitap[idAlani];
		if (Array.isArray(deger)) {
		deger.forEach((id) => set.add(id));
		} else if (deger !== null && deger !== undefined) {
		set.add(deger);
		}
		});
		return set;
		}

		function filtreSecenekleriniGuncelle() {
		facetKategorileri.forEach((kategori) => {
		const kitaplarBuKategoriHaric = kategoriHaricFiltrele(kategori.ad);
		const gecerliIdler = gecerliIdSetiOlustur(
		kitaplarBuKategoriHaric,
		kategori.idAlan,
		);

		const liste = document.getElementById("list-" + kategori.ad);
		if (!liste) return;

		liste.querySelectorAll(".filter-option").forEach((secenek) => {
		const checkbox = secenek.querySelector('input[type="checkbox"]');
		const id = parseInt(checkbox.value);
		const gecerli = gecerliIdler.has(id);
		// Seçili olan bir seçenek geçersiz hale gelse bile gizlenmez,
		// böylece kullanıcı seçimini görüp kaldırabilir.
		secenek.classList.toggle("gecersiz", !gecerli && !checkbox.checked);
		});
		});
		}

		function filtreleriSifirla() {
		// Tüm checkbox'ları temizle
		document
		.querySelectorAll('.filter-option input[type="checkbox"]')
		.forEach((cb) => {
		cb.checked = false;
		});

		// Arama kutularını da temizle ve gizlenmiş seçenekleri tekrar göster
		document.querySelectorAll(".filter-search").forEach((input) => {
		input.value = "";
		});
		document.querySelectorAll(".filter-option").forEach((opt) => {
		opt.classList.remove("arama-gizli", "gecersiz");
		});

		// Sayfa sayısı slider'larını min/max'e geri al
		const rangeMin = document.getElementById("range-min");
		const rangeMax = document.getElementById("range-max");
		rangeMin.value = rangeMin.min;
		rangeMax.value = rangeMax.max;
		document.getElementById("range-min-label").textContent = rangeMin.min;
		document.getElementById("range-max-label").textContent = rangeMax.max;

		// Açık filtre panellerini kapat (isteğe bağlı, ister kaldır)
		document.querySelectorAll(".filter-item.open").forEach((item) => {
		item.classList.remove("open");
		});

		filtreUygula();
		}

		// --- SERİ / İLGİLİ KİTAPLAR MANTIĞI ---
		// SeriesOrder: 1,2,3... ana seri kitapları. 100+ ise yan hikaye / evren notu vb.
		// Önceki kitap = seriesOrder - 1, sonraki kitap = seriesOrder + 1.
		// İlgili kitaplar = aynı seriye ait, önceki/sonraki dışındaki diğer tüm kitaplar.
		function serileriBul(kitap) {
		if (!kitap.seriesId) {
		return { onceki: null, sonraki: null, ilgili: [] };
		}

		const seride = tumKitaplar.filter(
		(k) => k.seriesId === kitap.seriesId && k.id !== kitap.id,
		);

		// Sadece ana seri (seriesOrder < 100) kitapları önceki/sonraki olabilir.
		// 100+ olanlar (yan hikaye / evren notu vb.) sadece "İlgili Kitaplar" listesine düşer,
		// ne kendileri önceki/sonraki gösterir ne de başka bir kitabın önceki/sonrakisi olabilir.
		const anaSeriKitaplari = seride.filter((k) => (k.seriesOrder ?? 0) < 100);
		const buKitapAnaSeride = (kitap.seriesOrder ?? 0) < 100;

		const onceki = buKitapAnaSeride
		? anaSeriKitaplari.find((k) => k.seriesOrder === kitap.seriesOrder - 1) ||
		null
		: null;
		const sonraki = buKitapAnaSeride
		? anaSeriKitaplari.find((k) => k.seriesOrder === kitap.seriesOrder + 1) ||
		null
		: null;

		const ilgili = seride
		.filter((k) => k !== onceki && k !== sonraki)
		.sort((a, b) => (a.seriesOrder ?? 0) - (b.seriesOrder ?? 0));

		return { onceki, sonraki, ilgili };
		}

		function seriSatirOlustur(kitap, etiket) {
		const satir = document.createElement("div");
		satir.className = "seri-kitap-satir";
		satir.onclick = () => popupAc(kitap);

		const etiketHtml = etiket ? `<span class="seri-etiket">${etiket}</span>` : "";

		satir.innerHTML = `
		<div class="seri-kitap-kapak"><img src="${kitap.kapak}" alt="${kitap.ad}" /></div>
		<div class="seri-kitap-bilgi">
		${etiketHtml}
		<span class="seri-kitap-adi">${kitap.ad}</span>
		</div>`;

		return satir;
		}

		function renderSeri(kitap) {
		const container = document.getElementById("popup-seri");
		container.innerHTML = "";

		const { onceki, sonraki, ilgili } = serileriBul(kitap);

		if (!onceki && !sonraki && ilgili.length === 0) {
		container.style.display = "none";
		return;
		}

		container.style.display = "flex";

		if (onceki) {
		container.appendChild(seriSatirOlustur(onceki, "Serinin Önceki Kitabı"));
		}
		if (sonraki) {
		container.appendChild(seriSatirOlustur(sonraki, "Serinin Sonraki Kitabı"));
		}

		if (ilgili.length > 0) {
		const baslik = document.createElement("div");
		baslik.className = "seri-baslik";
		baslik.textContent = "İlgili Kitaplar";
		container.appendChild(baslik);

		const liste = document.createElement("div");
		liste.className = "ilgili-liste";
		ilgili.forEach((k) => {
		const etiket =
		(k.seriesOrder ?? 0) < 100 ? `Ana Seri ${k.seriesOrder}. Kitap` : "";
		liste.appendChild(seriSatirOlustur(k, etiket));
		});
		container.appendChild(liste);
		}
		}
		let aktifKitapId = null;
		function popupAc(kitap) {
		aktifKitapId = kitap.id;
		document.getElementById("popup-kapak-img").src = kitap.kapak || "";
		document.getElementById("popup-kitap-adi").textContent = kitap.ad;
		document.getElementById("popup-yazar").textContent = kitap.yazar;
		document.getElementById("popup-yayinevi").textContent = kitap.yayinevi;
		document.getElementById("popup-ilk-yil").textContent = kitap.ilkYil || "—";
		document.getElementById("popup-basim-yili").textContent =
		kitap.basimYili || "—";
		document.getElementById("popup-sayfa").textContent = kitap.sayfa || "—";
		document.getElementById("popup-tur").textContent = kitap.tur || "—";
		document.getElementById("popup-cevirmen").textContent = kitap.cevirmen || "—";
		document.getElementById("popup-aciklama-metin").textContent =
		kitap.aciklama || "Açıklama bulunmuyor.";

		renderSeri(kitap);

		const kaydirmaAlani = document.getElementById("popup-scroll-alani");
		kaydirmaAlani.scrollTop = 0;

		document.getElementById("kitap-popup-overlay").classList.add("aktif");
		document.body.style.overflow = "hidden";
		}

		function kitapDuzenle() {
		if (!aktifKitapId) return;
		window.open("/Admin/Index?bookId=" + aktifKitapId, "_blank");
		}
		function popupKapat() {
		document.getElementById("kitap-popup-overlay").classList.remove("aktif");
		document.body.style.overflow = "";
		}

		// --- YAZAR POPUP MANTIĞI ---
		// Kitap popup'ındaki popupAc / popupKapat / kitapDuzenle üçlüsüyle
		// birebir aynı yapı; sadece yazar verisine göre çalışır. Yazarın kitap
		// listesi, ayrı bir sorgu yerine tumKitaplar içindeki yazarIds alanı
		// (ters ilişki) filtrelenerek elde edilir ve seri bölümündeki
		// seriSatirOlustur() satır deseni yeniden kullanılır.
		let aktifYazarId = null;

		function yazarYasamAraligiMetni(yazar) {
		if (!yazar.dogumYili) return "";
		const olum = yazar.olumYili ? yazar.olumYili : "yaşıyor";
		return `${yazar.dogumYili} – ${olum}`;
		}

		function yazarinKitaplariniBul(yazarId) {
		return tumKitaplar
		.filter((k) => Array.isArray(k.yazarIds) && k.yazarIds.includes(yazarId))
		.sort((a, b) => a.ad.localeCompare(b.ad, "tr-TR"));
		}

		function renderYazarKitaplari(yazarId) {
		const container = document.getElementById("yazar-popup-kitaplar");
		container.innerHTML = "";

		const kitaplar = yazarinKitaplariniBul(yazarId);
		if (kitaplar.length === 0) {
		container.style.display = "none";
		return;
		}
		container.style.display = "flex";

		const baslik = document.createElement("div");
		baslik.className = "seri-baslik";
		baslik.textContent = "Kitapları";
		container.appendChild(baslik);

		const liste = document.createElement("div");
		liste.className = "ilgili-liste";
		kitaplar.forEach((kitap) => {
		const satir = seriSatirOlustur(kitap, "");
		// Kitaba tıklanınca yazar popup'ı kapanır, Kitaplar sekmesine geçilir
		// ve o kitabın kendi detay popup'ı açılır.
		satir.onclick = () => {
		yazarPopupKapat();
		btnKitaplar.click();
		popupAc(kitap);
		};
		liste.appendChild(satir);
		});
		container.appendChild(liste);
		}

		function yazarPopupAc(yazar) {
		aktifYazarId = yazar.id;
		document.getElementById("yazar-popup-foto").src = yazar.foto || "";
		document.getElementById("yazar-popup-ad").textContent = yazar.ad;
		document.getElementById("yazar-popup-yasam").textContent =
		yazarYasamAraligiMetni(yazar) || "—";
		document.getElementById("yazar-popup-aciklama").textContent =
		yazar.aciklama || "Biyografi bulunmuyor.";

		renderYazarKitaplari(yazar.id);

		const kaydirmaAlani = document.getElementById("yazar-popup-scroll-alani");
		kaydirmaAlani.scrollTop = 0;

		document.getElementById("yazar-popup-overlay").classList.add("aktif");
		document.body.style.overflow = "hidden";
		}

		function yazarDuzenle() {
		if (!aktifYazarId) return;
		window.open("/Admin/Index?authorId=" + aktifYazarId, "_blank");
		}

		function yazarPopupKapat() {
		document.getElementById("yazar-popup-overlay").classList.remove("aktif");
		document.body.style.overflow = "";
		}

		// Türkçe karakterleri doğru küçülten, boşlukları yok sayan normalize fonksiyonu
		function normalizeMetin(str) {
		return str.toLocaleLowerCase("tr-TR").replace(/\s+/g, "");
		}

		// Arama sonucu bulunamadığında gösterilecek ejderha görseli ile
		// altındaki rastgele başlıklar
		const aramaBosYazilar = [
		"Ejderha kütüphaneyi dağıttı ama kitabı bulamadı.",
		"Ejderhamız aradı, taradı, bulamadı.",
		"Kütüphane ejderhası bütün rafları devirdi, kitap yine de yok.",
		"Ejderha elinden geleni yaptı ama bu kitap burada değil.",
		"Ejderhamız bu kadarını yapabildi, kusura bakma.",
		"Kitap yok, ejderha bahane üretiyor.",
		"Ejderha 'buradaydı' diyor ama kimse inanmıyor.",
		"Ejderha bu kadar aradı, kitap hâlâ yok.",
		"Ejderhamız didik didik aradı, sonuç sıfır.",
		"Ejderha 47 kitabı yere döktü, aradığın hâlâ yok.",
		"Ejderha bütün kuleyi yıktı, o kitap içinde çıkmadı.",
		"Ejderhamız üzgün, kitap yok.",
		"Bu sefer ejderha bile pes etti.",
		"0 sonuç bulundu, ejderha yerde bulundu.",
		];

		function aramaBosDurumGoster() {
		const rastgeleIndex = Math.floor(Math.random() * aramaBosYazilar.length);
		document.getElementById("arama-bos-yazi").textContent =
		aramaBosYazilar[rastgeleIndex];
		document.getElementById("arama-bos-durum").style.display = "flex";
		}

		function aramaBosDurumGizle() {
		document.getElementById("arama-bos-durum").style.display = "none";
		}

		function kitapAramaFiltrele() {
		const sorgu = normalizeMetin(
		document.getElementById("kitap-arama-input").value,
		);
		const kartlar = document.querySelectorAll("#view-kitaplar .book-card");

		let gorunenSayisi = 0;
		kartlar.forEach((kart) => {
		const baslikEl = kart.querySelector(".book-title");
		const baslik = normalizeMetin(baslikEl.textContent);
		const eslesiyor = sorgu === "" || baslik.includes(sorgu);
		kart.style.display = eslesiyor ? "flex" : "none";
		if (eslesiyor) gorunenSayisi++;
		});

		if (gorunenSayisi === 0) {
		aramaBosDurumGoster();
		} else {
		aramaBosDurumGizle();
		}
		}

		// Sayfa ilk açıldığında filtre seçeneklerinin geçerlilik durumunu hesapla
		filtreSecenekleriniGuncelle();

	</script>

</body>
